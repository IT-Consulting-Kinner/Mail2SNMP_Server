<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Mail2SNMP Server"
           Manufacturer="Adsumus"
           Version="1.0.0.0"
           UpgradeCode="E8F9A1B2-3C4D-5E6F-7A8B-9C0D1E2F3A4B"
           Compressed="yes"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Mail2SNMP is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Mail2SNMP Server" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ServiceComponents" />
      <ComponentGroupRef Id="MibComponents" />
      <ComponentGroupRef Id="DataDirectories" />
    </Feature>

    <!-- Directory Structure -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="COMPANYDIR" Name="IT-Consulting Kinner">
        <Directory Id="INSTALLFOLDER" Name="Mail2SNMP_Server">
          <Directory Id="MIBFOLDER" Name="MIB" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATACOMPANYDIR" Name="IT-Consulting Kinner">
        <Directory Id="DATADIRECTORY" Name="Mail2SNMP_Server">
          <Directory Id="KEYSDIRECTORY" Name="Key" />
          <Directory Id="LICENSEDIRECTORY" Name="License" />
          <Directory Id="LOGSDIRECTORY" Name="Logs" />
          <Directory Id="DBDIRECTORY" Name="data" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Application Files (all publish output) -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**">
        <Exclude Files="$(var.PublishDir)\Mail2SNMP.Worker.exe" />
      </Files>
    </ComponentGroup>

    <!-- Windows Service (exe + service registration) -->
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">
      <Component Id="WorkerService" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="WorkerExe" Source="$(var.PublishDir)\Mail2SNMP.Worker.exe" KeyPath="yes" />
        <ServiceInstall Id="Mail2SnmpWorkerService"
                        Type="ownProcess"
                        Name="Mail2SNMP"
                        DisplayName="Mail2SNMP Worker Service"
                        Description="Mail2SNMP - Mail to SNMP Trap / Webhook notification service"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal" />
        <ServiceControl Id="StartMail2SnmpService"
                        Name="Mail2SNMP"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

    <!-- MIB File -->
    <ComponentGroup Id="MibComponents" Directory="MIBFOLDER">
      <Component Id="MibFile" Guid="A7B8C9D0-E1F2-3456-ABCD-567890123456">
        <File Id="Mail2SnmpMib" Source="..\..\mib\Mail2SNMP-MIB.mib" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Data Directories (ProgramData) -->
    <ComponentGroup Id="DataDirectories">
      <Component Id="KeyDir" Directory="KEYSDIRECTORY" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <CreateFolder />
      </Component>
      <Component Id="LicenseDir" Directory="LICENSEDIRECTORY" Guid="D4E5F6A7-B8C9-0123-DEFA-234567890123">
        <CreateFolder />
      </Component>
      <Component Id="LogsDir" Directory="LOGSDIRECTORY" Guid="E5F6A7B8-C9D0-1234-EFAB-345678901234">
        <CreateFolder />
      </Component>
      <Component Id="DbDir" Directory="DBDIRECTORY" Guid="F6A7B8C9-D0E1-2345-FABC-456789012345">
        <CreateFolder />
      </Component>
    </ComponentGroup>

    <!-- Custom Actions for Prerequisites -->
    <Property Id="NETRUNTIME" Value="0" />

    <!-- UI -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- License -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
