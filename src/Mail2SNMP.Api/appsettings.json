{
  "Database": {
    "Provider": "Sqlite",
    "DatabaseName": "C:\\ProgramData\\IT-Consulting Kinner\\Mail2SNMP_Server\\data\\mail2snmp.db",
    "Server": "localhost",
    "Port": 1433,
    "Username": "",
    "Password": "",
    "IntegratedSecurity": false,
    "TrustServerCertificate": true,
    "Encrypt": true,
    "MultiSubnetFailover": false,
    "AdditionalOptions": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "%ProgramData%/IT-Consulting Kinner/Mail2SNMP_Server/Logs/mail2snmp-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Metrics": {
    "Enabled": false
  },
  "AllowedHosts": "*"
}
