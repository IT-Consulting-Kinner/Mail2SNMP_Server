@page "/schedules"
@rendermode InteractiveServer
@inject IScheduleService ScheduleService
@inject IJobService JobService
@inject IJSRuntime JS

<PageTitle>Schedules - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Schedules</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm"><i class="bi bi-plus-circle"></i> Add Schedule</button>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_schedules == null || _schedules.Count == 0)
{
    <div class="alert alert-info">No schedules configured yet. Click <strong>Add Schedule</strong> to create one.</div>
}
else
{
    <div class="mb-3 d-flex">
        <input type="text" class="form-control form-control-sm me-2" style="max-width:300px;"
               placeholder="Search by name or job..." @bind="_searchTerm" @bind:event="oninput" />
        @if (!string.IsNullOrEmpty(_searchTerm))
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _searchTerm = string.Empty">Clear</button>
        }
    </div>
    var filtered = (string.IsNullOrWhiteSpace(_searchTerm)
        ? (IEnumerable<Schedule>)_schedules
        : _schedules.Where(s =>
            (s.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (s.Job?.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))).ToList();
    @* N1+T10: prune selection only when the filter changes, not every render *@
    if (_searchTerm != _lastSearchTerm)
    {
        _lastSearchTerm = _searchTerm;
        var visibleIds = filtered.Select(s => s.Id).ToHashSet();
        _selected.RemoveWhere(id => !visibleIds.Contains(id));
    }
    @if (_selected.Count > 0)
    {
        <div class="alert alert-secondary d-flex align-items-center py-2 mb-2">
            <span class="me-3"><strong>@_selected.Count</strong> selected</span>
            <button class="btn btn-sm btn-outline-warning me-1" @onclick="BulkToggle" disabled="@_busy"><i class="bi bi-toggle-on"></i> Toggle</button>
            <button class="btn btn-sm btn-outline-danger me-1" @onclick="BulkDelete" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="() => _selected.Clear()">Clear selection</button>
        </div>
    }
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:30px;">
                    <input type="checkbox" class="form-check-input"
                           checked="@(_selected.Count == filtered.Count && filtered.Count > 0)"
                           @onchange="e => ToggleSelectAll((bool)e.Value!, filtered)" />
                </th>
                <th>Name</th>
                <th>Job</th>
                <th>Interval (min)</th>
                <th>Active</th>
                <th>Next Run</th>
                <th>Last Run</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (filtered.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-3">No schedules match the search term.</td></tr>
            }
            @foreach (var s in filtered)
            {
                <tr>
                    <td><input type="checkbox" class="form-check-input"
                               checked="@_selected.Contains(s.Id)"
                               @onchange="e => ToggleSelect(s.Id, (bool)e.Value!)" /></td>
                    <td>@s.Name</td>
                    <td>@(s.Job?.Name ?? $"ID:{s.JobId}")</td>
                    <td>@s.IntervalMinutes</td>
                    <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                    <td>@(s.NextRunUtc?.ToString("g") ?? "N/A")</td>
                    <td>@(s.LastRunUtc?.ToString("g") ?? "Never")</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ShowEditForm(s)" disabled="@_busy"><i class="bi bi-pencil"></i> Edit</button>
                        <button class="btn btn-outline-warning btn-sm me-1" @onclick="() => Toggle(s.Id)" disabled="@_busy"><i class="bi bi-toggle-on"></i> Toggle</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(s.Id)" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing != null ? "Edit" : "Add") Schedule</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                            <ValidationMessage For="@(() => _form.Name)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Job</label>
                            <InputSelect class="form-select" @bind-Value="_form.JobId">
                                <option value="0">-- Select --</option>
                                @if (_jobs != null)
                                {
                                    @foreach (var j in _jobs)
                                    {
                                        <option value="@j.Id">@j.Name</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _form.JobId)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Interval (minutes)</label>
                            <InputNumber class="form-control" @bind-Value="_form.IntervalMinutes" />
                            <ValidationMessage For="@(() => _form.IntervalMinutes)" class="text-danger small" />
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<Schedule>? _schedules;
    private IReadOnlyList<Job>? _jobs;
    private bool _showForm;
    private Schedule? _editing;
    private ScheduleForm _form = new();
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _busy;
    private string _searchTerm = string.Empty;
    private string? _lastSearchTerm;
    private HashSet<int> _selected = new();

    private void ToggleSelect(int id, bool isChecked)
    {
        if (isChecked) _selected.Add(id); else _selected.Remove(id);
    }

    private void ToggleSelectAll(bool isChecked, IEnumerable<Schedule> visible)
    {
        _selected.Clear();
        if (isChecked) foreach (var x in visible) _selected.Add(x.Id);
    }

    private async Task BulkToggle()
    {
        if (_busy || _selected.Count == 0) return;
        _busy = true;
        try
        {
            foreach (var id in _selected.ToList())
                await ScheduleService.ToggleAsync(id);
            _success = $"{_selected.Count} schedules toggled.";
            _selected.Clear();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "bulk-toggling schedules"); }
        finally { _busy = false; }
    }

    private async Task BulkDelete()
    {
        if (_busy || _selected.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete {_selected.Count} schedule(s)? This cannot be undone."))
            return;
        _busy = true;
        var failed = 0;
        try
        {
            foreach (var id in _selected.ToList())
            {
                try { await ScheduleService.DeleteAsync(id); }
                catch { failed++; }
            }
            if (failed > 0) _error = $"{failed} schedule(s) could not be deleted.";
            else _success = $"{_selected.Count} schedule(s) deleted.";
            _selected.Clear();
            await LoadData();
        }
        finally { _busy = false; }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _schedules = await ScheduleService.GetAllAsync();
            _jobs = await JobService.GetAllAsync();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    // I4: Always start with a fully fresh form. The previous version omitted
    // Name/JobId, so stale values from a prior edit/add could carry over.
    private void ShowAddForm()
    {
        _editing = null;
        _form = new ScheduleForm { Name = string.Empty, JobId = 0, IntervalMinutes = 5, IsActive = true };
        _showForm = true;
    }

    private void ShowEditForm(Schedule s)
    {
        _editing = s;
        _form = new ScheduleForm { Name = s.Name, JobId = s.JobId, IntervalMinutes = s.IntervalMinutes, IsActive = s.IsActive };
        _showForm = true;
    }

    // I4: Reset form on close so the next add/edit starts fresh.
    private void CloseForm()
    {
        _showForm = false;
        _editing = null;
        _form = new ScheduleForm { Name = string.Empty, JobId = 0, IntervalMinutes = 5, IsActive = true };
    }

    private async Task Save()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (_editing != null)
            {
                _editing.Name = _form.Name; _editing.JobId = _form.JobId;
                _editing.IntervalMinutes = _form.IntervalMinutes; _editing.IsActive = _form.IsActive;
                await ScheduleService.UpdateAsync(_editing);
                _success = "Schedule updated.";
            }
            else
            {
                var schedule = new Schedule
                {
                    Name = _form.Name, JobId = _form.JobId,
                    IntervalMinutes = _form.IntervalMinutes, IsActive = _form.IsActive
                };
                await ScheduleService.CreateAsync(schedule);
                _success = "Schedule created.";
            }
            CloseForm();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "saving the item"); }
        finally { _busy = false; }
    }

    private async Task Toggle(int id)
    {
        if (_busy) return;
        _busy = true;
        try { await ScheduleService.ToggleAsync(id); _success = "Schedule toggled."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "toggling the item"); }
        finally { _busy = false; }
    }

    private async Task Delete(int id)
    {
        if (_busy) return;
        var s = _schedules?.FirstOrDefault(x => x.Id == id);
        var name = s?.Name ?? $"#{id}";
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete schedule '{name}'? This cannot be undone."))
            return;
        _busy = true;
        try { await ScheduleService.DeleteAsync(id); _success = "Schedule deleted."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "deleting the item"); }
        finally { _busy = false; }
    }

    private class ScheduleForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [Range(1, int.MaxValue, ErrorMessage = "Please select a job.")]
        public int JobId { get; set; }

        [Range(1, 1440, ErrorMessage = "Interval must be between 1 and 1440 minutes.")]
        public int IntervalMinutes { get; set; } = 5;

        public bool IsActive { get; set; } = true;
    }
}
