@page "/mailboxes"
@rendermode InteractiveServer
@inject IMailboxService MailboxService
@inject IJSRuntime JS

<PageTitle>Mailboxes - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Mailboxes</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm"><i class="bi bi-plus-circle"></i> Add Mailbox</button>
</div>

@* M6: Auto-dismissible alerts. Success disappears after 5s; errors stay until closed. *@
<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_mailboxes == null || _mailboxes.Count == 0)
{
    <div class="alert alert-info">No mailboxes configured yet. Click <strong>Add Mailbox</strong> to create one.</div>
}
else
{
    @* M4: Client-side search filter on Name / Host / Username *@
    <div class="mb-3 d-flex">
        <input type="text" class="form-control form-control-sm me-2" style="max-width:300px;"
               placeholder="Search by name, host or username..." @bind="_searchTerm" @bind:event="oninput" />
        @if (!string.IsNullOrEmpty(_searchTerm))
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _searchTerm = string.Empty">Clear</button>
        }
    </div>
    var filtered = (string.IsNullOrWhiteSpace(_searchTerm)
        ? (IEnumerable<Mailbox>)_mailboxes
        : _mailboxes.Where(m =>
            (m.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (m.Host?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (m.Username?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))).ToList();
    @* N1+T10: keep _selected in sync with the visible (filtered) rows so a bulk
       action can never operate on items the user no longer sees. The pruning
       only runs when the search term changes (T10), not on every render. *@
    if (_searchTerm != _lastSearchTerm)
    {
        _lastSearchTerm = _searchTerm;
        var visibleIds = filtered.Select(m => m.Id).ToHashSet();
        _selected.RemoveWhere(id => !visibleIds.Contains(id));
    }
    @* L4: bulk action bar — only visible when at least one row is selected *@
    @if (_selected.Count > 0)
    {
        <div class="alert alert-secondary d-flex align-items-center py-2 mb-2">
            <span class="me-3"><strong>@_selected.Count</strong> selected</span>
            <button class="btn btn-sm btn-outline-success me-1" @onclick="BulkActivate" disabled="@_busy"><i class="bi bi-check-circle"></i> Activate</button>
            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="BulkDeactivate" disabled="@_busy"><i class="bi bi-pause-circle"></i> Deactivate</button>
            <button class="btn btn-sm btn-outline-danger me-1" @onclick="BulkDelete" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="() => _selected.Clear()">Clear selection</button>
        </div>
    }
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:30px;">
                    <input type="checkbox" class="form-check-input"
                           checked="@(_selected.Count == filtered.Count && filtered.Count > 0)"
                           @onchange="e => ToggleSelectAll((bool)e.Value!, filtered)" />
                </th>
                <th>Name</th>
                <th>Host</th>
                <th>Port</th>
                <th>Username</th>
                <th>Folder</th>
                <th>SSL</th>
                <th>Active</th>
                <th>Last Checked</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (filtered.Count == 0)
            {
                <tr><td colspan="10" class="text-center text-muted py-3">No mailboxes match the search term.</td></tr>
            }
            @foreach (var mb in filtered)
            {
                <tr>
                    <td><input type="checkbox" class="form-check-input"
                               checked="@_selected.Contains(mb.Id)"
                               @onchange="e => ToggleSelect(mb.Id, (bool)e.Value!)" /></td>
                    <td>@mb.Name</td>
                    <td>@mb.Host</td>
                    <td>@mb.Port</td>
                    <td>@mb.Username</td>
                    <td>@mb.Folder</td>
                    <td><span class="badge @(mb.UseSsl ? "bg-success" : "bg-secondary")">@(mb.UseSsl ? "Yes" : "No")</span></td>
                    <td><span class="badge @(mb.IsActive ? "bg-success" : "bg-secondary")">@(mb.IsActive ? "Active" : "Inactive")</span></td>
                    <td>@(mb.LastCheckedUtc?.ToString("g") ?? "Never")</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ShowEditForm(mb)" disabled="@_busy"><i class="bi bi-pencil"></i> Edit</button>
                        <button class="btn btn-outline-info btn-sm me-1" @onclick="() => TestConnection(mb.Id)" disabled="@_busy"><i class="bi bi-flask"></i> Test</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(mb.Id)" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing != null ? "Edit" : "Add") Mailbox</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="SaveMailbox">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                            <ValidationMessage For="@(() => _form.Name)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Host</label>
                            <InputText class="form-control" @bind-Value="_form.Host" />
                            <ValidationMessage For="@(() => _form.Host)" class="text-danger small" />
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label">Port</label>
                                <InputNumber class="form-control" @bind-Value="_form.Port" />
                                <ValidationMessage For="@(() => _form.Port)" class="text-danger small" />
                            </div>
                            <div class="col d-flex align-items-end">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_form.UseSsl" />
                                    <label class="form-check-label">Use SSL</label>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <InputText class="form-control" @bind-Value="_form.Username" />
                            <ValidationMessage For="@(() => _form.Username)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <InputText class="form-control" type="password" @bind-Value="_form.Password" />
                            <ValidationMessage For="@(() => _form.Password)" class="text-danger small" />
                            @if (_editing != null)
                            {
                                <small class="text-muted">Leave blank to keep existing password</small>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Folder</label>
                            <InputText class="form-control" @bind-Value="_form.Folder" />
                            <ValidationMessage For="@(() => _form.Folder)" class="text-danger small" />
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<Mailbox>? _mailboxes;
    private bool _showForm;
    private Mailbox? _editing;
    private MailboxForm _form = new();
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _busy;
    private string _searchTerm = string.Empty;
    private string? _lastSearchTerm;
    private HashSet<int> _selected = new();

    private void ToggleSelect(int id, bool isChecked)
    {
        if (isChecked) _selected.Add(id); else _selected.Remove(id);
    }

    private void ToggleSelectAll(bool isChecked, IEnumerable<Mailbox> visible)
    {
        _selected.Clear();
        if (isChecked) foreach (var m in visible) _selected.Add(m.Id);
    }

    private async Task BulkActivate() => await BulkSetActive(true);
    private async Task BulkDeactivate() => await BulkSetActive(false);

    private async Task BulkSetActive(bool active)
    {
        if (_busy || _selected.Count == 0) return;
        _busy = true;
        try
        {
            foreach (var id in _selected.ToList())
            {
                var mb = await MailboxService.GetByIdAsync(id);
                if (mb != null && mb.IsActive != active)
                {
                    mb.IsActive = active;
                    await MailboxService.UpdateAsync(mb);
                }
            }
            _success = $"{_selected.Count} mailboxes {(active ? "activated" : "deactivated")}.";
            _selected.Clear();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "bulk-updating mailboxes"); }
        finally { _busy = false; }
    }

    private async Task BulkDelete()
    {
        if (_busy || _selected.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm",
                $"Delete {_selected.Count} mailbox(es)? This cannot be undone."))
            return;
        _busy = true;
        var failed = 0;
        try
        {
            foreach (var id in _selected.ToList())
            {
                try { await MailboxService.DeleteAsync(id); }
                catch { failed++; }
            }
            if (failed > 0) _error = $"{failed} mailbox(es) could not be deleted (still in use).";
            else _success = $"{_selected.Count} mailbox(es) deleted.";
            _selected.Clear();
            await LoadData();
        }
        finally { _busy = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _mailboxes = await MailboxService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _error = ErrorMessageFormatter.ToFriendly(ex, "loading mailboxes");
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowAddForm()
    {
        _editing = null;
        _form = new MailboxForm { Port = 993, UseSsl = true, Folder = "INBOX", IsActive = true, IsEditing = false };
        _showForm = true;
    }

    private void ShowEditForm(Mailbox mb)
    {
        _editing = mb;
        _form = new MailboxForm
        {
            Name = mb.Name,
            Host = mb.Host,
            Port = mb.Port,
            UseSsl = mb.UseSsl,
            Username = mb.Username,
            Folder = mb.Folder,
            IsActive = mb.IsActive,
            IsEditing = true
        };
        _showForm = true;
    }

    // J2: Reset form state on close so the password field (and every other input)
    // cannot leak from a previous edit into the next add or edit dialog.
    private void CloseForm()
    {
        _showForm = false;
        _editing = null;
        _form = new MailboxForm { Port = 993, UseSsl = true, Folder = "INBOX", IsActive = true, IsEditing = false };
    }

    private async Task SaveMailbox()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (_editing != null)
            {
                _editing.Name = _form.Name;
                _editing.Host = _form.Host;
                _editing.Port = _form.Port;
                _editing.UseSsl = _form.UseSsl;
                _editing.Username = _form.Username;
                _editing.Folder = _form.Folder;
                _editing.IsActive = _form.IsActive;
                if (!string.IsNullOrEmpty(_form.Password))
                    _editing.EncryptedPassword = _form.Password;
                await MailboxService.UpdateAsync(_editing);
                _success = "Mailbox updated successfully.";
            }
            else
            {
                var mailbox = new Mailbox
                {
                    Name = _form.Name,
                    Host = _form.Host,
                    Port = _form.Port,
                    UseSsl = _form.UseSsl,
                    Username = _form.Username,
                    EncryptedPassword = _form.Password ?? string.Empty,
                    Folder = _form.Folder,
                    IsActive = _form.IsActive
                };
                await MailboxService.CreateAsync(mailbox);
                _success = "Mailbox created successfully.";
            }

            CloseForm();
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = ErrorMessageFormatter.ToFriendly(ex, "saving the mailbox");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task TestConnection(int id)
    {
        if (_busy) return;
        _busy = true;
        _success = null;
        _error = null;
        try
        {
            var result = await MailboxService.TestConnectionAsync(id);
            if (result)
                _success = "Connection successful!";
            else
                _error = "Connection test failed. Check the worker log for details.";
        }
        catch (Exception ex)
        {
            _error = ErrorMessageFormatter.ToFriendly(ex, "running the test");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Delete(int id)
    {
        if (_busy) return;
        var mb = _mailboxes?.FirstOrDefault(m => m.Id == id);
        var name = mb?.Name ?? $"#{id}";
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete mailbox '{name}'? This cannot be undone."))
            return;
        _busy = true;
        try
        {
            await MailboxService.DeleteAsync(id);
            _success = "Mailbox deleted.";
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = ErrorMessageFormatter.ToFriendly(ex, "deleting the item");
        }
        finally
        {
            _busy = false;
        }
    }

    private class MailboxForm : IValidatableObject
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Host is required.")]
        public string Host { get; set; } = string.Empty;

        [Range(1, 65535, ErrorMessage = "Port must be between 1 and 65535.")]
        public int Port { get; set; } = 993;

        public bool UseSsl { get; set; } = true;

        [Required(ErrorMessage = "Username is required.")]
        public string Username { get; set; } = string.Empty;

        public string? Password { get; set; }

        [Required(ErrorMessage = "Folder is required.")]
        public string Folder { get; set; } = "INBOX";

        public bool IsActive { get; set; } = true;
        public bool IsEditing { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (!IsEditing && string.IsNullOrWhiteSpace(Password))
                yield return new ValidationResult("Password is required.", new[] { nameof(Password) });
        }
    }
}
