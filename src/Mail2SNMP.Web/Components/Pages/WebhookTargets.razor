@page "/webhook-targets"
@rendermode InteractiveServer
@inject IWebhookTargetService WebhookTargetService
@inject IJSRuntime JS

<PageTitle>Webhook Targets - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Webhook Targets</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm"><i class="bi bi-plus-circle"></i> Add Target</button>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_targets == null || _targets.Count == 0)
{
    <div class="alert alert-info">No webhook targets configured yet. Click <strong>Add Target</strong> to create one.</div>
}
else
{
    <div class="mb-3 d-flex">
        <input type="text" class="form-control form-control-sm me-2" style="max-width:300px;"
               placeholder="Search by name or URL..." @bind="_searchTerm" @bind:event="oninput" />
        @if (!string.IsNullOrEmpty(_searchTerm))
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _searchTerm = string.Empty">Clear</button>
        }
    </div>
    var filtered = (string.IsNullOrWhiteSpace(_searchTerm)
        ? (IEnumerable<WebhookTarget>)_targets
        : _targets.Where(t =>
            (t.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (t.Url?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))).ToList();
    @* N1: prune selection so bulk actions only ever touch visible rows *@
    var _visibleIds = filtered.Select(t => t.Id).ToHashSet();
    _selected.RemoveWhere(id => !_visibleIds.Contains(id));
    @if (_selected.Count > 0)
    {
        <div class="alert alert-secondary d-flex align-items-center py-2 mb-2">
            <span class="me-3"><strong>@_selected.Count</strong> selected</span>
            <button class="btn btn-sm btn-outline-success me-1" @onclick="BulkActivate" disabled="@_busy"><i class="bi bi-check-circle"></i> Activate</button>
            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="BulkDeactivate" disabled="@_busy"><i class="bi bi-pause-circle"></i> Deactivate</button>
            <button class="btn btn-sm btn-outline-danger me-1" @onclick="BulkDelete" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="() => _selected.Clear()">Clear selection</button>
        </div>
    }
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:30px;">
                    <input type="checkbox" class="form-check-input"
                           checked="@(_selected.Count == filtered.Count && filtered.Count > 0)"
                           @onchange="e => ToggleSelectAll((bool)e.Value!, filtered)" />
                </th>
                <th>Name</th>
                <th>URL</th>
                <th>Max Req/Min</th>
                <th>Active</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (filtered.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-3">No targets match the search term.</td></tr>
            }
            @foreach (var t in filtered)
            {
                <tr>
                    <td><input type="checkbox" class="form-check-input"
                               checked="@_selected.Contains(t.Id)"
                               @onchange="e => ToggleSelect(t.Id, (bool)e.Value!)" /></td>
                    <td>@t.Name</td>
                    <td><code class="small">@t.Url</code></td>
                    <td>@t.MaxRequestsPerMinute</td>
                    <td><span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                    <td>@t.CreatedUtc.ToString("g")</td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ShowEditForm(t)" disabled="@_busy"><i class="bi bi-pencil"></i> Edit</button>
                        <button class="btn btn-outline-info btn-sm me-1" @onclick="() => Test(t.Id)" disabled="@_busy"><i class="bi bi-flask"></i> Test</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(t.Id)" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing != null ? "Edit" : "Add") Webhook Target</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                            <ValidationMessage For="@(() => _form.Name)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">URL</label>
                            <InputText class="form-control" @bind-Value="_form.Url" />
                            <ValidationMessage For="@(() => _form.Url)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Headers (JSON)</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="_form.Headers" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Payload Template</label>
                            <InputTextArea class="form-control" rows="4" @bind-Value="_form.PayloadTemplate" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Secret</label>
                            <InputText class="form-control" type="password" @bind-Value="_form.Secret" />
                            @if (_editing != null)
                            {
                                <small class="text-muted">Leave blank to keep existing secret</small>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Requests/Minute</label>
                            <InputNumber class="form-control" @bind-Value="_form.MaxRequestsPerMinute" />
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<WebhookTarget>? _targets;
    private bool _showForm;
    private WebhookTarget? _editing;
    private WebhookForm _form = new();
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _busy;
    private string _searchTerm = string.Empty;
    private HashSet<int> _selected = new();

    private void ToggleSelect(int id, bool isChecked)
    {
        if (isChecked) _selected.Add(id); else _selected.Remove(id);
    }

    private void ToggleSelectAll(bool isChecked, IEnumerable<WebhookTarget> visible)
    {
        _selected.Clear();
        if (isChecked) foreach (var x in visible) _selected.Add(x.Id);
    }

    private async Task BulkActivate() => await BulkSetActive(true);
    private async Task BulkDeactivate() => await BulkSetActive(false);

    private async Task BulkSetActive(bool active)
    {
        if (_busy || _selected.Count == 0) return;
        _busy = true;
        try
        {
            foreach (var id in _selected.ToList())
            {
                var x = await WebhookTargetService.GetByIdAsync(id);
                if (x != null && x.IsActive != active) { x.IsActive = active; await WebhookTargetService.UpdateAsync(x); }
            }
            _success = $"{_selected.Count} targets {(active ? "activated" : "deactivated")}.";
            _selected.Clear();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "bulk-updating targets"); }
        finally { _busy = false; }
    }

    private async Task BulkDelete()
    {
        if (_busy || _selected.Count == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete {_selected.Count} webhook target(s)? This cannot be undone."))
            return;
        _busy = true;
        var failed = 0;
        try
        {
            foreach (var id in _selected.ToList())
            {
                try { await WebhookTargetService.DeleteAsync(id); }
                catch { failed++; }
            }
            if (failed > 0) _error = $"{failed} target(s) could not be deleted (still in use).";
            else _success = $"{_selected.Count} target(s) deleted.";
            _selected.Clear();
            await LoadData();
        }
        finally { _busy = false; }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try { _targets = await WebhookTargetService.GetAllAsync(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private void ShowAddForm()
    {
        _editing = null;
        _form = new WebhookForm { MaxRequestsPerMinute = 60, IsActive = true };
        _showForm = true;
    }

    private void ShowEditForm(WebhookTarget t)
    {
        _editing = t;
        _form = new WebhookForm
        {
            Name = t.Name, Url = t.Url, Headers = t.Headers,
            PayloadTemplate = t.PayloadTemplate, MaxRequestsPerMinute = t.MaxRequestsPerMinute, IsActive = t.IsActive
        };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editing = null; }

    private async Task Save()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (_editing != null)
            {
                _editing.Name = _form.Name; _editing.Url = _form.Url;
                _editing.Headers = _form.Headers; _editing.PayloadTemplate = _form.PayloadTemplate;
                _editing.MaxRequestsPerMinute = _form.MaxRequestsPerMinute; _editing.IsActive = _form.IsActive;
                if (!string.IsNullOrEmpty(_form.Secret)) _editing.EncryptedSecret = _form.Secret;
                await WebhookTargetService.UpdateAsync(_editing);
                _success = "Webhook target updated.";
            }
            else
            {
                var target = new WebhookTarget
                {
                    Name = _form.Name, Url = _form.Url, Headers = _form.Headers,
                    PayloadTemplate = _form.PayloadTemplate, EncryptedSecret = _form.Secret ?? string.Empty,
                    MaxRequestsPerMinute = _form.MaxRequestsPerMinute, IsActive = _form.IsActive
                };
                await WebhookTargetService.CreateAsync(target);
                _success = "Webhook target created.";
            }
            CloseForm();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "saving the item"); }
        finally { _busy = false; }
    }

    private async Task Test(int id)
    {
        if (_busy) return;
        _busy = true;
        _success = null;
        _error = null;
        try
        {
            var result = await WebhookTargetService.TestAsync(id);
            if (result) _success = "Webhook test successful!";
            else _error = "Webhook test failed. Check the worker log for details.";
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "running the test"); }
        finally { _busy = false; }
    }

    private async Task Delete(int id)
    {
        if (_busy) return;
        var t = _targets?.FirstOrDefault(x => x.Id == id);
        var name = t?.Name ?? $"#{id}";
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete webhook target '{name}'? This cannot be undone."))
            return;
        _busy = true;
        try { await WebhookTargetService.DeleteAsync(id); _success = "Target deleted."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "deleting the item"); }
        finally { _busy = false; }
    }

    private class WebhookForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "URL is required.")]
        [Url(ErrorMessage = "Please enter a valid URL.")]
        public string Url { get; set; } = string.Empty;

        public string? Headers { get; set; }
        public string? PayloadTemplate { get; set; }
        public string? Secret { get; set; }

        [Range(1, 10000, ErrorMessage = "Max requests per minute must be between 1 and 10,000.")]
        public int MaxRequestsPerMinute { get; set; } = 60;

        public bool IsActive { get; set; } = true;
    }
}
