@page "/"
@rendermode InteractiveServer
@using Mail2SNMP.Infrastructure.Data
@using Mail2SNMP.Models.Entities
@using Microsoft.EntityFrameworkCore
@using System.Reflection
@inject IMailboxService MailboxService
@inject IJobService JobService
@inject IScheduleService ScheduleService
@inject IEventService EventService
@inject IDeadLetterService DeadLetterService
@inject IMaintenanceWindowService MaintenanceService
@inject ILicenseProvider LicenseProvider
@inject Mail2SnmpDbContext Db
@using Mail2SNMP.Infrastructure.Services

<PageTitle>Dashboard - Mail2SNMP</PageTitle>

<h3 class="mb-4">Dashboard</h3>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @* M2: License banner — visible when license is missing, expired, or expiring soon *@
    @if (_license != null)
    {
        if (_license.ExpiresUtc.HasValue && _license.ExpiresUtc.Value < DateTime.UtcNow)
        {
            <div class="alert alert-danger d-flex align-items-center" role="alert">
                <strong class="me-2">⚠ License expired</strong>
                <span>on @_license.ExpiresUtc.Value.ToString("yyyy-MM-dd"). The system has fallen back to <strong>Community Edition</strong> limits. Please renew your license to restore Enterprise features.</span>
            </div>
        }
        else if (_license.Edition == LicenseEdition.Community)
        {
            <div class="alert alert-info d-flex align-items-center" role="alert">
                <strong class="me-2">Community Edition</strong>
                <span>— max @_license.MaxMailboxes mailboxes, @_license.MaxJobs jobs, @_license.MaxWorkerInstances worker instance. Upgrade to Enterprise for unlimited resources, SNMPv3, OIDC SSO, and webhook dead-letter retries.</span>
            </div>
        }
        else if (_license.ExpiresUtc.HasValue && _license.ExpiresUtc.Value < DateTime.UtcNow.AddDays(30))
        {
            <div class="alert alert-warning d-flex align-items-center" role="alert">
                <strong class="me-2">License expiring soon</strong>
                <span>on @_license.ExpiresUtc.Value.ToString("yyyy-MM-dd") (in @((int)(_license.ExpiresUtc.Value - DateTime.UtcNow).TotalDays) days). Please renew before that date to avoid downgrade.</span>
            </div>
        }
    }

    <div class="row g-3">
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Active Mailboxes</h6>
                    <h2 class="card-title mb-0">@_dashboard.ActiveMailboxes</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Active Jobs</h6>
                    <h2 class="card-title mb-0">@_dashboard.ActiveJobs</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Active Schedules</h6>
                    <h2 class="card-title mb-0">@_dashboard.ActiveSchedules</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm @(_dashboard.OpenEvents > 0 ? "border-warning" : "")">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Open Events</h6>
                    <h2 class="card-title mb-0 @(_dashboard.OpenEvents > 0 ? "text-warning" : "")">@_dashboard.OpenEvents</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm @(_dashboard.PendingDeadLetters > 0 ? "border-danger" : "")">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Pending Dead Letters</h6>
                    <h2 class="card-title mb-0 @(_dashboard.PendingDeadLetters > 0 ? "text-danger" : "")">@_dashboard.PendingDeadLetters</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">License Edition</h6>
                    <h2 class="card-title mb-0">@_dashboard.LicenseEdition</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Maintenance</h6>
                    <h2 class="card-title mb-0 @(_dashboard.MaintenanceActive ? "text-warning" : "text-success")">
                        @(_dashboard.MaintenanceActive ? "Active" : "None")
                    </h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">System Health</h6>
                    <h2 class="card-title mb-0 @(_dashboard.IsHealthy ? "text-success" : "text-danger")">
                        @(_dashboard.IsHealthy ? "Healthy" : "Degraded")
                    </h2>
                </div>
            </div>
        </div>
    </div>

    @* M3: Channel overflow indicator — non-zero means the IMAP polling channel is saturated. *@
    @if (_channelOverflow > 0)
    {
        <div class="alert alert-warning mt-3" role="alert">
            <strong>⚠ Channel saturation:</strong> @_channelOverflow mail polling job(s) were dropped because the worker channel was full.
            Consider increasing <code>Imap.ChannelBoundedCapacity</code> or <code>Imap.ConsumerTasks</code> in <code>appsettings.json</code>.
        </div>
    }

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Mail2SNMP Server Version</h6>
                    <p class="mb-1"><strong>Installed:</strong> @_currentVersion</p>
                    @if (!string.IsNullOrEmpty(_availableVersion) && _updateAvailable)
                    {
                        <div class="alert alert-info mt-2 mb-0">
                            <strong>Update available:</strong> @_availableVersion (@_publishDate)
                            @if (!string.IsNullOrEmpty(_downloadLink))
                            {
                                <a href="@_downloadLink" target="_blank" class="ms-2">Download</a>
                            }
                        </div>
                    }
                    else
                    {
                        <small class="text-muted">No update available.</small>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }
}

@code {
    private DashboardDto _dashboard = new();
    private bool _loading = true;
    private string? _error;
    private string _currentVersion = "0.0.0";
    private string _availableVersion = string.Empty;
    private string _publishDate = string.Empty;
    private string _downloadLink = string.Empty;
    private bool _updateAvailable = false;
    private LicenseInfo? _license;
    private double _channelOverflow;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var mailboxes = await MailboxService.GetAllAsync();
            var jobs = await JobService.GetAllAsync();
            var schedules = await ScheduleService.GetAllAsync();
            var events = await EventService.GetAllAsync(EventState.New);
            var notifiedEvents = await EventService.GetAllAsync(EventState.Notified);
            var deadLetters = await DeadLetterService.GetAllAsync();
            var inMaintenance = await MaintenanceService.IsInMaintenanceAsync();

            _dashboard = new DashboardDto
            {
                ActiveMailboxes = mailboxes.Count(m => m.IsActive),
                ActiveJobs = jobs.Count(j => j.IsActive),
                ActiveSchedules = schedules.Count(s => s.IsActive),
                OpenEvents = events.Count + notifiedEvents.Count,
                PendingDeadLetters = deadLetters.Count(d => d.Status == DeadLetterStatus.Pending),
                MaintenanceActive = inMaintenance,
                LicenseEdition = LicenseProvider.Current.Edition.ToString(),
                IsHealthy = true
            };
            _license = LicenseProvider.Current;

            // M3: read the in-process Prometheus counter so the dashboard surfaces
            // saturation events even when the Prometheus endpoint is disabled.
            _channelOverflow = Mail2SnmpMetrics.ChannelOverflow.Value;

            // Load version + update info
            _currentVersion = Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? "0.0.0";
            var available = await Db.Settings.AsNoTracking().FirstOrDefaultAsync(s => s.Key == "update.available_version");
            var date      = await Db.Settings.AsNoTracking().FirstOrDefaultAsync(s => s.Key == "update.publish_date");
            var link      = await Db.Settings.AsNoTracking().FirstOrDefaultAsync(s => s.Key == "update.download_link");
            _availableVersion = available?.Value ?? string.Empty;
            _publishDate      = date?.Value ?? string.Empty;
            _downloadLink     = link?.Value ?? string.Empty;
            _updateAvailable  = !string.IsNullOrEmpty(_availableVersion)
                && !string.Equals(_availableVersion, _currentVersion, StringComparison.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load dashboard: {ex.Message}";
            _dashboard.IsHealthy = false;
        }
        finally
        {
            _loading = false;
        }
    }
}
