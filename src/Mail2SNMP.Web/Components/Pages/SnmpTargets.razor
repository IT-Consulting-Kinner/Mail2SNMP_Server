@page "/snmp-targets"
@rendermode InteractiveServer
@inject ISnmpTargetService SnmpTargetService
@inject IJSRuntime JS

<PageTitle>SNMP Targets - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">SNMP Targets</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm"><i class="bi bi-plus-circle"></i> Add Target</button>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_targets == null || _targets.Count == 0)
{
    <div class="alert alert-info">No SNMP targets configured yet. Click <strong>Add Target</strong> to create one.</div>
}
else
{
    <div class="mb-3 d-flex">
        <input type="text" class="form-control form-control-sm me-2" style="max-width:300px;"
               placeholder="Search by name or host..." @bind="_searchTerm" @bind:event="oninput" />
        @if (!string.IsNullOrEmpty(_searchTerm))
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _searchTerm = string.Empty">Clear</button>
        }
    </div>
    var filtered = (string.IsNullOrWhiteSpace(_searchTerm)
        ? (IEnumerable<SnmpTarget>)_targets
        : _targets.Where(t =>
            (t.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (t.Host?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))).ToList();
    @* N1+T10: prune selection only when the filter changes, not every render *@
    if (_searchTerm != _lastSearchTerm)
    {
        _lastSearchTerm = _searchTerm;
        var visibleIds = filtered.Select(t => t.Id).ToHashSet();
        _selected.RemoveWhere(id => !visibleIds.Contains(id));
    }
    @if (_selected.Count > 0)
    {
        <div class="alert alert-secondary d-flex align-items-center py-2 mb-2">
            <span class="me-3"><strong>@_selected.Count</strong> selected</span>
            <button class="btn btn-sm btn-outline-success me-1" @onclick="BulkActivate" disabled="@_busy"><i class="bi bi-check-circle"></i> Activate</button>
            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="BulkDeactivate" disabled="@_busy"><i class="bi bi-pause-circle"></i> Deactivate</button>
            <button class="btn btn-sm btn-outline-danger me-1" @onclick="BulkDelete" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="() => _selected.Clear()">Clear selection</button>
        </div>
    }
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:30px;">
                    <input type="checkbox" class="form-check-input"
                           checked="@(_selected.Count == filtered.Count && filtered.Count > 0)"
                           @onchange="e => ToggleSelectAll((bool)e.Value!, filtered)" />
                </th>
                <th>Name</th>
                <th>Host</th>
                <th>Port</th>
                <th>Version</th>
                <th>Community / Security</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (filtered.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-3">No targets match the search term.</td></tr>
            }
            @foreach (var t in filtered)
            {
                <tr>
                    <td><input type="checkbox" class="form-check-input"
                               checked="@_selected.Contains(t.Id)"
                               @onchange="e => ToggleSelect(t.Id, (bool)e.Value!)" /></td>
                    <td>@t.Name</td>
                    <td>@t.Host</td>
                    <td>@t.Port</td>
                    <td>@t.Version</td>
                    <td>
                        @if (t.Version == SnmpVersion.V3)
                        {
                            <span>@t.SecurityName (@t.AuthProtocol/@t.PrivProtocol)</span>
                        }
                        else
                        {
                            <span>@(string.IsNullOrEmpty(t.CommunityString) ? "N/A" : "***")</span>
                        }
                    </td>
                    <td><span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ShowEditForm(t)" disabled="@_busy"><i class="bi bi-pencil"></i> Edit</button>
                        <button class="btn btn-outline-info btn-sm me-1" @onclick="() => Test(t.Id)" disabled="@_busy"><i class="bi bi-flask"></i> Test</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(t.Id)" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing != null ? "Edit" : "Add") SNMP Target</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                            <ValidationMessage For="@(() => _form.Name)" class="text-danger small" />
                        </div>
                        <div class="row mb-3">
                            <div class="col-8">
                                <label class="form-label">Host</label>
                                <InputText class="form-control" @bind-Value="_form.Host" />
                                <ValidationMessage For="@(() => _form.Host)" class="text-danger small" />
                            </div>
                            <div class="col-4">
                                <label class="form-label">Port</label>
                                <InputNumber class="form-control" @bind-Value="_form.Port" />
                                <ValidationMessage For="@(() => _form.Port)" class="text-danger small" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Version</label>
                            <InputSelect class="form-select" @bind-Value="_form.Version">
                                @foreach (var val in Enum.GetValues<SnmpVersion>())
                                {
                                    <option value="@val">@val</option>
                                }
                            </InputSelect>
                        </div>

                        @if (_form.Version == SnmpVersion.V1 || _form.Version == SnmpVersion.V2c)
                        {
                            <div class="mb-3">
                                <label class="form-label">Community String</label>
                                <InputText class="form-control" @bind-Value="_form.CommunityString" />
                                <ValidationMessage For="@(() => _form.CommunityString)" class="text-danger small" />
                            </div>
                        }

                        @if (_form.Version == SnmpVersion.V3)
                        {
                            <div class="mb-3">
                                <label class="form-label">Security Name</label>
                                <InputText class="form-control" @bind-Value="_form.SecurityName" />
                                <ValidationMessage For="@(() => _form.SecurityName)" class="text-danger small" />
                            </div>
                            <div class="row mb-3">
                                <div class="col">
                                    <label class="form-label">Auth Protocol</label>
                                    <InputSelect class="form-select" @bind-Value="_form.AuthProtocol">
                                        @foreach (var val in Enum.GetValues<AuthProtocol>())
                                        {
                                            <option value="@val">@val</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _form.AuthProtocol)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label">Auth Password</label>
                                    <InputText class="form-control" type="password" @bind-Value="_form.AuthPassword" />
                                    <ValidationMessage For="@(() => _form.AuthPassword)" class="text-danger small" />
                                    @if (_editing != null)
                                    {
                                        <small class="text-muted">Leave blank to keep the existing password.</small>
                                    }
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col">
                                    <label class="form-label">Privacy Protocol</label>
                                    <InputSelect class="form-select" @bind-Value="_form.PrivProtocol">
                                        @foreach (var val in Enum.GetValues<PrivProtocol>())
                                        {
                                            <option value="@val">@val</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _form.PrivProtocol)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label">Privacy Password</label>
                                    <InputText class="form-control" type="password" @bind-Value="_form.PrivPassword" />
                                    <ValidationMessage For="@(() => _form.PrivPassword)" class="text-danger small" />
                                    @if (_editing != null)
                                    {
                                        <small class="text-muted">Leave blank to keep the existing password.</small>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Engine ID</label>
                                <InputText class="form-control" @bind-Value="_form.EngineId" />
                                <ValidationMessage For="@(() => _form.EngineId)" class="text-danger small" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Enterprise Trap OID</label>
                            <InputText class="form-control" @bind-Value="_form.EnterpriseTrapOid" />
                            <ValidationMessage For="@(() => _form.EnterpriseTrapOid)" class="text-danger small" />
                            <small class="form-text text-muted">Default: 1.3.6.1.4.1.61376.1.2.0.1 (mail2SNMPEventCreatedNotification)</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Traps/Minute</label>
                            <InputNumber class="form-control" @bind-Value="_form.MaxTrapsPerMinute" />
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.SendKeepAlive" />
                            <label class="form-check-label">Send KeepAlive Traps</label>
                            <small class="form-text text-muted d-block">When enabled, this target receives periodic keep-alive traps from the worker (interval configured in appsettings.json &gt; KeepAlive).</small>
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<SnmpTarget>? _targets;
    private bool _showForm;
    private SnmpTarget? _editing;
    private SnmpTargetForm _form = new();
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _busy;
    private string _searchTerm = string.Empty;
    private string? _lastSearchTerm;
    private HashSet<int> _selected = new();

    private void ToggleSelect(int id, bool isChecked)
    {
        if (isChecked) _selected.Add(id); else _selected.Remove(id);
    }

    private void ToggleSelectAll(bool isChecked, IEnumerable<SnmpTarget> visible)
    {
        _selected.Clear();
        if (isChecked) foreach (var x in visible) _selected.Add(x.Id);
    }

    private async Task BulkActivate() => await BulkSetActive(true);
    private async Task BulkDeactivate() => await BulkSetActive(false);

    private async Task BulkSetActive(bool active)
    {
        if (_busy || _selected.Count == 0) return;
        _busy = true;
        try
        {
            foreach (var id in _selected.ToList())
            {
                var x = await SnmpTargetService.GetByIdAsync(id);
                if (x != null && x.IsActive != active) { x.IsActive = active; await SnmpTargetService.UpdateAsync(x); }
            }
            _success = $"{_selected.Count} targets {(active ? "activated" : "deactivated")}.";
            _selected.Clear();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "bulk-updating targets"); }
        finally { _busy = false; }
    }

    private async Task BulkDelete()
    {
        if (_busy || _selected.Count == 0) return;
        if (!await JS.TryConfirmAsync($"Delete {_selected.Count} SNMP target(s)? This cannot be undone."))
            return;
        _busy = true;
        var failed = 0;
        try
        {
            foreach (var id in _selected.ToList())
            {
                try { await SnmpTargetService.DeleteAsync(id); }
                catch { failed++; }
            }
            if (failed > 0) _error = $"{failed} target(s) could not be deleted (still in use).";
            else _success = $"{_selected.Count} target(s) deleted.";
            _selected.Clear();
            await LoadData();
        }
        finally { _busy = false; }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try { _targets = await SnmpTargetService.GetAllAsync(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private void ShowAddForm()
    {
        _editing = null;
        _form = new SnmpTargetForm { Port = 162, Version = SnmpVersion.V2c, MaxTrapsPerMinute = 100, IsActive = true, SendKeepAlive = false, IsEditing = false };
        _showForm = true;
    }

    private void ShowEditForm(SnmpTarget t)
    {
        _editing = t;
        _form = new SnmpTargetForm
        {
            Name = t.Name, Host = t.Host, Port = t.Port, Version = t.Version,
            CommunityString = t.CommunityString, SecurityName = t.SecurityName,
            AuthProtocol = t.AuthProtocol, PrivProtocol = t.PrivProtocol,
            EngineId = t.EngineId, EnterpriseTrapOid = t.EnterpriseTrapOid,
            MaxTrapsPerMinute = t.MaxTrapsPerMinute, SendKeepAlive = t.SendKeepAlive, IsActive = t.IsActive,
            IsEditing = true
        };
        _showForm = true;
    }

    // I3: Reset form state on close so V3 password fields and other inputs cannot
    // leak across edit dialogs.
    private void CloseForm()
    {
        _showForm = false;
        _editing = null;
        _form = new SnmpTargetForm { Port = 162, Version = SnmpVersion.V2c, MaxTrapsPerMinute = 100, IsActive = true, SendKeepAlive = false, IsEditing = false };
    }

    private async Task Save()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (_editing != null)
            {
                _editing.Name = _form.Name; _editing.Host = _form.Host; _editing.Port = _form.Port;
                _editing.Version = _form.Version; _editing.CommunityString = _form.CommunityString;
                _editing.SecurityName = _form.SecurityName; _editing.AuthProtocol = _form.AuthProtocol;
                _editing.PrivProtocol = _form.PrivProtocol; _editing.EngineId = _form.EngineId;
                _editing.EnterpriseTrapOid = _form.EnterpriseTrapOid;
                _editing.MaxTrapsPerMinute = _form.MaxTrapsPerMinute;
                _editing.SendKeepAlive = _form.SendKeepAlive;
                _editing.IsActive = _form.IsActive;
                if (!string.IsNullOrEmpty(_form.AuthPassword)) _editing.EncryptedAuthPassword = _form.AuthPassword;
                if (!string.IsNullOrEmpty(_form.PrivPassword)) _editing.EncryptedPrivPassword = _form.PrivPassword;
                await SnmpTargetService.UpdateAsync(_editing);
                _success = "SNMP target updated.";
            }
            else
            {
                var target = new SnmpTarget
                {
                    Name = _form.Name, Host = _form.Host, Port = _form.Port, Version = _form.Version,
                    CommunityString = _form.CommunityString, SecurityName = _form.SecurityName,
                    AuthProtocol = _form.AuthProtocol, EncryptedAuthPassword = _form.AuthPassword ?? string.Empty,
                    PrivProtocol = _form.PrivProtocol, EncryptedPrivPassword = _form.PrivPassword ?? string.Empty,
                    EngineId = _form.EngineId, EnterpriseTrapOid = _form.EnterpriseTrapOid,
                    MaxTrapsPerMinute = _form.MaxTrapsPerMinute, SendKeepAlive = _form.SendKeepAlive, IsActive = _form.IsActive
                };
                await SnmpTargetService.CreateAsync(target);
                _success = "SNMP target created.";
            }
            CloseForm();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "saving the item"); }
        finally { _busy = false; }
    }

    private async Task Test(int id)
    {
        if (_busy) return;
        _busy = true;
        _success = null;
        _error = null;
        try
        {
            var result = await SnmpTargetService.TestAsync(id);
            if (result) _success = "SNMP test successful!";
            else _error = "SNMP test failed. Check the worker log for details.";
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "running the test"); }
        finally { _busy = false; }
    }

    private async Task Delete(int id)
    {
        // Q1: see Jobs.Delete — _busy must be set BEFORE the confirm dialog.
        if (_busy) return;
        _busy = true;
        try
        {
            var t = _targets?.FirstOrDefault(x => x.Id == id);
            var name = t?.Name ?? $"#{id}";
            if (!await JS.TryConfirmAsync($"Delete SNMP target '{name}'? This cannot be undone."))
                return;
            await SnmpTargetService.DeleteAsync(id);
            _success = "Target deleted.";
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "deleting the item"); }
        finally { _busy = false; }
    }

    private class SnmpTargetForm : IValidatableObject
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Host is required.")]
        public string Host { get; set; } = string.Empty;

        [Range(1, 65535, ErrorMessage = "Port must be between 1 and 65535.")]
        public int Port { get; set; } = 162;

        public SnmpVersion Version { get; set; } = SnmpVersion.V2c;
        public string? CommunityString { get; set; }
        public string? SecurityName { get; set; }
        public AuthProtocol AuthProtocol { get; set; }
        public string? AuthPassword { get; set; }
        public PrivProtocol PrivProtocol { get; set; }
        public string? PrivPassword { get; set; }
        public string? EngineId { get; set; }
        public string? EnterpriseTrapOid { get; set; }

        [Range(1, 10000, ErrorMessage = "Max traps per minute must be between 1 and 10,000.")]
        public int MaxTrapsPerMinute { get; set; } = 100;

        public bool SendKeepAlive { get; set; } = false;
        public bool IsActive { get; set; } = true;
        public bool IsEditing { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (Version == SnmpVersion.V1 || Version == SnmpVersion.V2c)
            {
                if (string.IsNullOrWhiteSpace(CommunityString))
                    yield return new ValidationResult("Community string is required for SNMP v1/v2c.", new[] { nameof(CommunityString) });
            }
            else if (Version == SnmpVersion.V3)
            {
                if (string.IsNullOrWhiteSpace(SecurityName))
                    yield return new ValidationResult("Security name is required for SNMP v3.", new[] { nameof(SecurityName) });
                if (AuthProtocol != AuthProtocol.None && !IsEditing && string.IsNullOrWhiteSpace(AuthPassword))
                    yield return new ValidationResult("Auth password is required when auth protocol is set.", new[] { nameof(AuthPassword) });
                if (PrivProtocol != PrivProtocol.None && !IsEditing && string.IsNullOrWhiteSpace(PrivPassword))
                    yield return new ValidationResult("Privacy password is required when privacy protocol is set.", new[] { nameof(PrivPassword) });
            }
        }
    }
}
