@page "/dead-letters"
@rendermode InteractiveServer
@inject IDeadLetterService DeadLetterService
@inject IJSRuntime JS

<PageTitle>Dead Letters - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Dead Letters</h3>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_entries == null || _entries.Count == 0)
{
    <div class="alert alert-info">No dead letter entries found.</div>
}
else
{
    var totalPages = (int)Math.Ceiling(_entries.Count / (double)_pageSize);
    var paged = _entries.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Webhook Target</th>
                <th>Event ID</th>
                <th>Status</th>
                <th>Attempts</th>
                <th>Last Error</th>
                <th>Created</th>
                <th>Next Retry</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in paged)
            {
                <tr>
                    <td>@entry.Id</td>
                    <td>@(entry.WebhookTarget?.Name ?? $"ID:{entry.WebhookTargetId}")</td>
                    <td>@entry.EventId</td>
                    <td><span class="badge bg-@GetStatusColor(entry.Status)">@entry.Status</span></td>
                    <td>@entry.AttemptCount</td>
                    <td class="small text-truncate" style="max-width: 200px;" title="@entry.LastError">@entry.LastError</td>
                    <td class="small">@entry.CreatedUtc.ToString("g")</td>
                    <td class="small">@(entry.NextRetryUtc?.ToString("g") ?? "N/A")</td>
                    <td>
                        @if (entry.Status == DeadLetterStatus.Pending)
                        {
                            <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => Retry(entry.Id)" disabled="@_busy"><i class="bi bi-arrow-clockwise"></i> Retry</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<nav class="d-flex justify-content-between align-items-center">
    <div>
        <small class="text-muted me-3">Showing @((_currentPage - 1) * _pageSize + 1)–@Math.Min(_currentPage * _pageSize, _entries.Count) of @_entries.Count entries</small>
        <button class="btn btn-warning btn-sm" @onclick="RetryAll" disabled="@_busy">Retry All Pending</button>
    </div>
    @if (totalPages > 1)
    {
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => _currentPage = Math.Max(1, _currentPage - 1)">Previous</button>
            </li>
            <li class="page-item disabled"><span class="page-link">Page @_currentPage of @totalPages</span></li>
            <li class="page-item @(_currentPage == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => _currentPage = Math.Min(totalPages, _currentPage + 1)">Next</button>
            </li>
        </ul>
    }
</nav>
}

@code {
    private IReadOnlyList<DeadLetterEntry>? _entries;
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _busy;
    private const int _pageSize = 50;
    private int _currentPage = 1;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _entries = await DeadLetterService.GetAllAsync();
            _currentPage = 1;
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private async Task Retry(long id)
    {
        if (_busy) return;
        _busy = true;
        try { await DeadLetterService.RetryAsync(id); _success = "Retry queued."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "retrying the entry"); }
        finally { _busy = false; }
    }

    private async Task RetryAll()
    {
        if (_busy) return;
        var pending = _entries?.Count(e => e.Status == DeadLetterStatus.Pending) ?? 0;
        if (pending == 0)
        {
            _error = "No pending entries to retry.";
            return;
        }
        if (!await JS.InvokeAsync<bool>("confirm",
                $"Retry {pending} pending dead letter entries? This may send many webhook requests."))
            return;
        _busy = true;
        try
        {
            var webhookIds = _entries?
                .Where(e => e.Status == DeadLetterStatus.Pending)
                .Select(e => e.WebhookTargetId)
                .Distinct()
                .ToList() ?? new List<int>();

            foreach (var whId in webhookIds)
            {
                await DeadLetterService.RetryAllAsync(whId);
            }
            _success = "All pending entries queued for retry.";
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "retrying all entries"); }
        finally { _busy = false; }
    }

    private static string GetStatusColor(DeadLetterStatus s) => s switch
    {
        DeadLetterStatus.Pending => "warning",
        DeadLetterStatus.Locked => "info",
        DeadLetterStatus.Abandoned => "danger",
        _ => "secondary"
    };
}
