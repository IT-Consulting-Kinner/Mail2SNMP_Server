@page "/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Operator")]
@rendermode InteractiveServer
@inject IAuditService AuditService
@inject IJSRuntime JS

<PageTitle>Audit Log - Mail2SNMP</PageTitle>

<h3 class="mb-3">Audit Log</h3>

<AutoDismissAlert Type="danger" @bind-Message="_error" />

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <label class="form-label">Action Filter</label>
        <input type="text" class="form-control form-control-sm" @bind="_actionFilter" @bind:event="oninput" placeholder="e.g. Create, Delete..." />
    </div>
    <div class="col-md-3">
        <label class="form-label">From</label>
        <input type="datetime-local" class="form-control form-control-sm" @bind="_fromDate" />
    </div>
    <div class="col-md-3">
        <label class="form-label">To</label>
        <input type="datetime-local" class="form-control form-control-sm" @bind="_toDate" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary btn-sm me-2" @onclick="ApplyFilter">Search</button>
        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="ClearFilter">Clear</button>
        @* Wave C (12): export the currently filtered audit set as CSV *@
        <button class="btn btn-outline-success btn-sm" @onclick="ExportCsv" disabled="@(_events == null || _events.Count == 0)"><i class="bi bi-download"></i> CSV</button>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_events == null || _events.Count == 0)
{
    <div class="alert alert-info">No audit entries found for the current filter.</div>
}
else
{
    var totalPages = (int)Math.Ceiling(_events.Count / (double)_pageSize);
    var paged = _events.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
@* L2: Mobile-responsive table — secondary columns are hidden below md/lg breakpoints. *@
<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Timestamp</th>
                <th class="d-none d-md-table-cell">Actor</th>
                <th class="d-none d-lg-table-cell">Type</th>
                <th>Action</th>
                <th class="d-none d-md-table-cell">Target</th>
                <th>Result</th>
                <th class="d-none d-xl-table-cell">Details</th>
                <th class="d-none d-lg-table-cell">IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var evt in paged)
            {
                <tr>
                    <td class="small">@evt.TimestampUtc.ToString("g")</td>
                    <td class="small d-none d-md-table-cell">@evt.ActorId</td>
                    <td class="d-none d-lg-table-cell"><span class="badge bg-secondary">@evt.ActorType</span></td>
                    <td>@evt.Action</td>
                    <td class="small d-none d-md-table-cell">@evt.TargetType @evt.TargetId</td>
                    <td><span class="badge bg-@GetResultColor(evt.Result)">@evt.Result</span></td>
                    <td class="small text-truncate d-none d-xl-table-cell" style="max-width: 200px;" title="@evt.Details">@evt.Details</td>
                    <td class="small d-none d-lg-table-cell">@evt.IpAddress</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<nav class="d-flex justify-content-between align-items-center" aria-label="Pagination">
    <small class="text-muted">Showing @((_currentPage - 1) * _pageSize + 1)–@Math.Min(_currentPage * _pageSize, _events.Count) of @_events.Count entries</small>
    @if (totalPages > 1)
    {
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => _currentPage = Math.Max(1, _currentPage - 1)">Previous</button>
            </li>
            <li class="page-item disabled" aria-current="page"><span class="page-link">Page @_currentPage of @totalPages</span></li>
            <li class="page-item @(_currentPage == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => _currentPage = Math.Min(totalPages, _currentPage + 1)">Next</button>
            </li>
        </ul>
    }
</nav>
}

@code {
    private IReadOnlyList<AuditEvent>? _events;
    private string? _actionFilter;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string? _error;
    private bool _loading = true;
    private const int _pageSize = 50;
    private int _currentPage = 1;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _events = await AuditService.GetAllAsync(
                string.IsNullOrWhiteSpace(_actionFilter) ? null : _actionFilter,
                _fromDate, _toDate);
            _currentPage = 1;
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private async Task ApplyFilter() => await LoadData();

    private async Task ClearFilter()
    {
        _actionFilter = null;
        _fromDate = null;
        _toDate = null;
        await LoadData();
    }

    private static string GetResultColor(AuditResult r) => r switch
    {
        AuditResult.Success => "success",
        AuditResult.Failure => "danger",
        AuditResult.Denied => "warning",
        _ => "secondary"
    };

    // Wave C (12): build a CSV string from the currently filtered events and trigger
    // a browser download via a small JS interop helper.
    private async Task ExportCsv()
    {
        if (_events == null || _events.Count == 0) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("TimestampUtc,ActorType,ActorId,Action,TargetType,TargetId,Result,IpAddress,UserAgent,Details");
        foreach (var e in _events)
        {
            sb.Append(e.TimestampUtc.ToString("o")).Append(',')
              .Append(Csv(e.ActorType.ToString())).Append(',')
              .Append(Csv(e.ActorId)).Append(',')
              .Append(Csv(e.Action)).Append(',')
              .Append(Csv(e.TargetType)).Append(',')
              .Append(Csv(e.TargetId)).Append(',')
              .Append(Csv(e.Result.ToString())).Append(',')
              .Append(Csv(e.IpAddress)).Append(',')
              .Append(Csv(e.UserAgent)).Append(',')
              .AppendLine(Csv(e.Details));
        }
        var filename = $"audit-{DateTime.UtcNow:yyyyMMdd-HHmmss}.csv";
        await JS.InvokeVoidAsync("mail2snmp.downloadText", filename, "text/csv;charset=utf-8", sb.ToString());
    }

    // RFC4180-style minimal CSV quoting: escape quotes by doubling, wrap if comma/quote/newline present.
    private static string Csv(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        var needsQuote = value.IndexOfAny(new[] { ',', '"', '\n', '\r' }) >= 0;
        var escaped = value.Replace("\"", "\"\"");
        return needsQuote ? $"\"{escaped}\"" : escaped;
    }
}
