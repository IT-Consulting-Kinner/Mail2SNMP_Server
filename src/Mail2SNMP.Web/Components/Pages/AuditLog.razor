@page "/audit"
@rendermode InteractiveServer
@inject IAuditService AuditService

<PageTitle>Audit Log - Mail2SNMP</PageTitle>

<h3 class="mb-3">Audit Log</h3>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger alert-dismissible">@_error <button type="button" class="btn-close" @onclick="() => _error = null"></button></div>
}

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <label class="form-label">Action Filter</label>
        <input type="text" class="form-control form-control-sm" @bind="_actionFilter" @bind:event="oninput" placeholder="e.g. Create, Delete..." />
    </div>
    <div class="col-md-3">
        <label class="form-label">From</label>
        <input type="datetime-local" class="form-control form-control-sm" @bind="_fromDate" />
    </div>
    <div class="col-md-3">
        <label class="form-label">To</label>
        <input type="datetime-local" class="form-control form-control-sm" @bind="_toDate" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary btn-sm me-2" @onclick="ApplyFilter">Search</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilter">Clear</button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Timestamp</th>
                <th>Actor</th>
                <th>Type</th>
                <th>Action</th>
                <th>Target</th>
                <th>Result</th>
                <th>Details</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @if (_events != null)
            {
                @foreach (var evt in _events)
                {
                    <tr>
                        <td class="small">@evt.TimestampUtc.ToString("g")</td>
                        <td class="small">@evt.ActorId</td>
                        <td><span class="badge bg-secondary">@evt.ActorType</span></td>
                        <td>@evt.Action</td>
                        <td class="small">@evt.TargetType @evt.TargetId</td>
                        <td><span class="badge bg-@GetResultColor(evt.Result)">@evt.Result</span></td>
                        <td class="small text-truncate" style="max-width: 200px;" title="@evt.Details">@evt.Details</td>
                        <td class="small">@evt.IpAddress</td>
                    </tr>
                }

                @if (_events.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">No audit entries found.</td></tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private IReadOnlyList<AuditEvent>? _events;
    private string? _actionFilter;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            _events = await AuditService.GetAllAsync(
                string.IsNullOrWhiteSpace(_actionFilter) ? null : _actionFilter,
                _fromDate, _toDate);
        }
        catch (Exception ex) { _error = $"Failed to load: {ex.Message}"; }
    }

    private async Task ApplyFilter() => await LoadData();

    private async Task ClearFilter()
    {
        _actionFilter = null;
        _fromDate = null;
        _toDate = null;
        await LoadData();
    }

    private static string GetResultColor(AuditResult r) => r switch
    {
        AuditResult.Success => "success",
        AuditResult.Failure => "danger",
        AuditResult.Denied => "warning",
        _ => "secondary"
    };
}
