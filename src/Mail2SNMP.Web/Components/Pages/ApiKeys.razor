@page "/api-keys"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@rendermode InteractiveServer
@using System.Security.Cryptography
@using Mail2SNMP.Infrastructure.Data
@using Mail2SNMP.Infrastructure.Security
@using Mail2SNMP.Models.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject Mail2SnmpDbContext Db
@inject IJSRuntime JS
@inject ConfirmService Confirm
@inject IOptions<HelpSettings> Help
@inject AuthenticationStateProvider AuthState

<PageTitle>API Keys - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">API Keys <HelpLink Url="@Help.Value.ApiKeys" /></h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate"><i class="bi bi-plus-circle"></i> Create Key</button>
</div>

<AutoDismissAlert Type="danger" @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_newKeyPlaintext != null)
{
    <div class="alert alert-warning">
        <h5><i class="bi bi-shield-lock"></i> Save this key now</h5>
        <p>This is the <strong>only</strong> time you will see the full key. Copy it now — it cannot be recovered.</p>
        <code class="d-block p-2 bg-dark text-white user-select-all">@_newKeyPlaintext</code>
        <div class="mt-2">
            @* H10: explicit Copy-to-Clipboard button so users do not lose the key by mistake *@
            <button class="btn btn-sm btn-success me-2" @onclick="CopyKey"><i class="bi bi-clipboard"></i> Copy to clipboard</button>
            <button class="btn btn-sm btn-secondary" @onclick="() => _newKeyPlaintext = null">I have saved it</button>
        </div>
    </div>
}

@if (_keys == null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_keys.Count == 0)
{
    <div class="alert alert-info">No API keys yet. Click <strong>Create Key</strong> to add one.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th><th>Prefix</th><th>Scopes</th><th>Active</th>
                    <th>Created</th><th>Expires</th><th>Last Used</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var k in _keys)
                {
                    <tr>
                        <td>@k.Name</td>
                        <td><code>@k.KeyPrefix...</code></td>
                        <td>@k.Scopes</td>
                        <td><span class="badge @(k.IsActive ? "bg-success" : "bg-secondary")">@(k.IsActive ? "Active" : "Disabled")</span></td>
                        <td class="small">@k.CreatedUtc.ToString("g")</td>
                        <td class="small">@(k.ExpiresUtc?.ToString("g") ?? "Never")</td>
                        <td class="small">@(k.LastUsedUtc?.ToString("g") ?? "Never")</td>
                        <td>
                            <button class="btn btn-outline-warning btn-sm me-1" @onclick="() => Toggle(k.Id)" disabled="@_busy"><i class="bi bi-toggle-on"></i></button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(k.Id)" disabled="@_busy"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create API Key</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                @* K9: Wrap the create form in an HTML <form> so pressing Enter in
                   any input submits via the Create button — consistent with every
                   other modal in the app, which use Blazor's EditForm for the same
                   purpose. We can't use EditForm here because the inputs are bound
                   to plain fields rather than a model class. *@
                <form @onsubmit="Create" @onsubmit:preventDefault="true">
                    <div class="modal-body">
                        @* H12: surface validation errors so users see why Create did nothing *@
                        @if (!string.IsNullOrEmpty(_formError))
                        {
                            <div class="alert alert-danger py-2 small">@_formError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            @* K8: autofocus first input. *@
                            <input class="form-control" @bind="_formName" placeholder="e.g. Grafana scraper" autofocus />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Scopes</label>
                            <select class="form-select" @bind="_formScopes">
                                <option value="read">read (GET only)</option>
                                <option value="read,write">read,write (GET/POST/PUT/DELETE)</option>
                                <option value="admin">admin (full access)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Expires (optional)</label>
                            <input type="date" class="form-control" @bind="_formExpires" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@code {
    private List<ApiKey>? _keys;
    private bool _busy;
    private bool _showForm;
    private string? _error;
    private string? _success;
    private string? _newKeyPlaintext;
    private string? _formError;
    private string _formName = string.Empty;
    private string _formScopes = "read";
    private DateTime? _formExpires;

    private async Task CopyKey()
    {
        // H10: copy the one-time plaintext to the clipboard via JS interop.
        if (string.IsNullOrEmpty(_newKeyPlaintext)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _newKeyPlaintext);
            _success = "API key copied to clipboard.";
        }
        catch (Exception ex) { _error = "Could not copy: " + ex.Message; }
    }

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try { _keys = await Db.ApiKeys.OrderByDescending(k => k.CreatedUtc).ToListAsync(); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void ShowCreate()
    {
        _formName = string.Empty;
        _formScopes = "read";
        _formExpires = null;
        _formError = null;
        _showForm = true;
    }

    // J3 + K1: Single close path that resets every form field AND clears the
    // one-time plaintext key. Without K1 the previously-shown key would remain
    // displayed at the top of the page after the user closed the modal without
    // clicking "I have saved it" — and would re-appear on every navigation back.
    private void CloseForm()
    {
        _showForm = false;
        _formName = string.Empty;
        _formScopes = "read";
        _formExpires = null;
        _formError = null;
        _newKeyPlaintext = null;
    }

    private async Task Create()
    {
        _formError = null;
        if (string.IsNullOrWhiteSpace(_formName)) { _formError = "Name is required."; return; }
        _busy = true;
        try
        {
            // Generate a 256-bit random key, base64url-encoded for compactness
            var bytes = new byte[32];
            RandomNumberGenerator.Fill(bytes);
            var plaintext = "m2s_" + Convert.ToBase64String(bytes).Replace('+', '-').Replace('/', '_').TrimEnd('=');

            var auth = await AuthState.GetAuthenticationStateAsync();
            var key = new ApiKey
            {
                Name = _formName.Trim(),
                Scopes = _formScopes,
                KeyHash = ApiKeyAuthenticationHandler.HashKey(plaintext),
                KeyPrefix = plaintext.Substring(0, Math.Min(8, plaintext.Length)),
                CreatedUtc = DateTime.UtcNow,
                ExpiresUtc = _formExpires?.ToUniversalTime(),
                CreatedBy = auth.User.Identity?.Name ?? "unknown",
                IsActive = true
            };
            Db.ApiKeys.Add(key);
            await Db.SaveChangesAsync();

            _newKeyPlaintext = plaintext;
            _showForm = false;
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    // Q2: Toggle and Delete previously had no _busy tracking at all, so the
    // disabled="@_busy" markup on their buttons was cosmetic. A fast double-
    // click could run two parallel SaveChangesAsync calls on the same key.
    // Both methods now follow the same pattern as every other action method:
    // guard with `if (_busy) return;`, set _busy=true, run inside try/finally.

    private async Task Toggle(int id)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var k = await Db.ApiKeys.FindAsync(id);
            if (k == null) return;
            k.IsActive = !k.IsActive;
            await Db.SaveChangesAsync();
            _success = $"Key '{k.Name}' is now {(k.IsActive ? "active" : "disabled")}.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Delete(int id)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (!await Confirm.AskAsync("Delete this API key? Any clients using it will lose access immediately.")) return;
            var k = await Db.ApiKeys.FindAsync(id);
            if (k == null) return;
            Db.ApiKeys.Remove(k);
            await Db.SaveChangesAsync();
            _success = "Key deleted.";
            await Load();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
