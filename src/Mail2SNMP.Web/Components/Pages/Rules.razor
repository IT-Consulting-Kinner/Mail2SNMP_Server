@page "/rules"
@rendermode InteractiveServer
@inject IRuleService RuleService

<PageTitle>Rules - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Rules</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm">Add Rule</button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}
@if (!string.IsNullOrEmpty(_success))
{
    <div class="alert alert-success alert-dismissible">
        @_success
        <button type="button" class="btn-close" @onclick="() => _success = null"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Field</th>
                <th>Match Type</th>
                <th>Criteria</th>
                <th>Severity</th>
                <th>Priority</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (_rules != null)
            {
                @foreach (var rule in _rules)
                {
                    <tr>
                        <td>@rule.Name</td>
                        <td>@rule.Field</td>
                        <td>@rule.MatchType</td>
                        <td><code>@rule.Criteria</code></td>
                        <td><span class="badge bg-@GetSeverityColor(rule.Severity)">@rule.Severity</span></td>
                        <td>@rule.Priority</td>
                        <td><span class="badge @(rule.IsActive ? "bg-success" : "bg-secondary")">@(rule.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ShowEditForm(rule)">Edit</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(rule.Id)">Delete</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing != null ? "Edit" : "Add") Rule</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="SaveRule">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <ValidationSummary class="text-danger" />
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Field</label>
                            <InputSelect class="form-select" @bind-Value="_form.Field">
                                @foreach (var val in Enum.GetValues<RuleFieldType>())
                                {
                                    <option value="@val">@val</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Match Type</label>
                            <InputSelect class="form-select" @bind-Value="_form.MatchType">
                                @foreach (var val in Enum.GetValues<RuleMatchType>())
                                {
                                    <option value="@val">@val</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Criteria</label>
                            <InputText class="form-control" @bind-Value="_form.Criteria" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Severity</label>
                            <InputSelect class="form-select" @bind-Value="_form.Severity">
                                @foreach (var val in Enum.GetValues<Severity>())
                                {
                                    <option value="@val">@val</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <InputNumber class="form-control" @bind-Value="_form.Priority" />
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<Rule>? _rules;
    private bool _showForm;
    private Rule? _editing;
    private RuleForm _form = new();
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try { _rules = await RuleService.GetAllAsync(); }
        catch (Exception ex) { _error = $"Failed to load rules: {ex.Message}"; }
    }

    private void ShowAddForm()
    {
        _editing = null;
        _form = new RuleForm { IsActive = true, Severity = Severity.Warning };
        _showForm = true;
    }

    private void ShowEditForm(Rule r)
    {
        _editing = r;
        _form = new RuleForm
        {
            Name = r.Name, Field = r.Field, MatchType = r.MatchType,
            Criteria = r.Criteria, Severity = r.Severity, Priority = r.Priority, IsActive = r.IsActive
        };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editing = null; }

    private async Task SaveRule()
    {
        try
        {
            if (_editing != null)
            {
                _editing.Name = _form.Name; _editing.Field = _form.Field;
                _editing.MatchType = _form.MatchType; _editing.Criteria = _form.Criteria;
                _editing.Severity = _form.Severity; _editing.Priority = _form.Priority;
                _editing.IsActive = _form.IsActive;
                await RuleService.UpdateAsync(_editing);
                _success = "Rule updated.";
            }
            else
            {
                var rule = new Rule
                {
                    Name = _form.Name, Field = _form.Field, MatchType = _form.MatchType,
                    Criteria = _form.Criteria, Severity = _form.Severity, Priority = _form.Priority, IsActive = _form.IsActive
                };
                await RuleService.CreateAsync(rule);
                _success = "Rule created.";
            }
            CloseForm();
            await LoadData();
        }
        catch (Exception ex) { _error = $"Failed to save rule: {ex.Message}"; }
    }

    private async Task Delete(int id)
    {
        try { await RuleService.DeleteAsync(id); _success = "Rule deleted."; await LoadData(); }
        catch (Exception ex) { _error = $"Failed to delete: {ex.Message}"; }
    }

    private static string GetSeverityColor(Severity s) => s switch
    {
        Severity.Critical => "danger",
        Severity.Error => "danger",
        Severity.Warning => "warning",
        _ => "info"
    };

    private class RuleForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        public RuleFieldType Field { get; set; }
        public RuleMatchType MatchType { get; set; }

        [Required(ErrorMessage = "Criteria is required.")]
        public string Criteria { get; set; } = string.Empty;

        public Severity Severity { get; set; } = Severity.Warning;
        public int Priority { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
