@page "/jobs"
@rendermode InteractiveServer
@inject IJobService JobService
@inject IMailboxService MailboxService
@inject IRuleService RuleService
@inject ISnmpTargetService SnmpTargetService
@inject IWebhookTargetService WebhookTargetService
@inject IJSRuntime JS
@inject ConfirmService Confirm
@inject IOptions<HelpSettings> Help

<PageTitle>Jobs - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Jobs <HelpLink Url="@Help.Value.Jobs" /></h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm"><i class="bi bi-plus-circle"></i> Add Job</button>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (!string.IsNullOrEmpty(_dryRunResult))
{
    <div class="alert alert-info alert-dismissible">
        <h6>Dry Run Result:</h6>
        <pre class="mb-0">@_dryRunResult</pre>
        <button type="button" class="btn-close" @onclick="() => _dryRunResult = null"></button>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_jobs == null || _jobs.Count == 0)
{
    <div class="alert alert-info">No jobs configured yet. Click <strong>Add Job</strong> to create one.</div>
}
else
{
    <div class="mb-3 d-flex">
        @* T1: debounced *@
        <div style="max-width:300px;" class="me-2 flex-grow-1">
            <DebouncedSearchInput Value="_searchTerm" ValueChanged="v => _searchTerm = v"
                                  Placeholder="Search by name, mailbox or rule…" />
        </div>
        @if (!string.IsNullOrEmpty(_searchTerm))
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _searchTerm = string.Empty">Clear</button>
        }
    </div>
    var filtered = (string.IsNullOrWhiteSpace(_searchTerm)
        ? (IEnumerable<Job>)_jobs
        : _jobs.Where(j =>
            (j.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (j.Mailbox?.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (j.Rule?.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))).ToList();
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Mailbox</th>
                <th>Rule</th>
                <th>Targets</th>
                <th>Max Events/Hr</th>
                <th>Dedup (min)</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (filtered.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-3">No jobs match the search term.</td></tr>
            }
            @foreach (var job in filtered)
            {
                <tr>
                    <td>@job.Name</td>
                    <td>@(job.Mailbox?.Name ?? $"ID:{job.MailboxId}")</td>
                    <td>@(job.Rule?.Name ?? $"ID:{job.RuleId}")</td>
                    <td>
                        @if (job.JobSnmpTargets.Any())
                        {
                            @foreach (var jst in job.JobSnmpTargets)
                            {
                                <a href="/snmp-targets" class="badge bg-info text-decoration-none me-1" title="@jst.SnmpTarget.Host:@jst.SnmpTarget.Port">@jst.SnmpTarget.Name</a>
                            }
                        }
                        @if (job.JobWebhookTargets.Any())
                        {
                            @foreach (var jwt in job.JobWebhookTargets)
                            {
                                <a href="/webhook-targets" class="badge bg-primary text-decoration-none me-1" title="@jwt.WebhookTarget.Url">@jwt.WebhookTarget.Name</a>
                            }
                        }
                        @if (!job.JobSnmpTargets.Any() && !job.JobWebhookTargets.Any())
                        {
                            <span class="badge bg-warning text-dark" title="Job has no notification targets — events will be created but no traps/webhooks sent">no targets</span>
                        }
                    </td>
                    <td>@job.MaxEventsPerHour</td>
                    <td>@job.DedupWindowMinutes</td>
                    <td><span class="badge @(job.IsActive ? "bg-success" : "bg-secondary")">@(job.IsActive ? "Active" : "Inactive")</span></td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => ShowEditForm(job)" disabled="@_busy"><i class="bi bi-pencil"></i> Edit</button>
                        <button class="btn btn-outline-warning btn-sm me-1" @onclick="() => DryRun(job.Id)" disabled="@_busy"><i class="bi bi-play-circle"></i> Dry Run</button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(job.Id)" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing != null ? "Edit" : "Add") Job</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="SaveJob" OnInvalidSubmit="OnInvalidSubmit">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @* L6: tabbed layout for the job form. N5: tabs that contain
                           required fields show a red dot when their content is invalid. *@
                        @{
                            var basicHasError = string.IsNullOrWhiteSpace(_form.Name) || _form.MailboxId <= 0 || _form.RuleId <= 0;
                        }
                        <ul class="nav nav-tabs mb-3" role="tablist">
                            <li class="nav-item"><button type="button" class="nav-link @(_activeTab == "basic" ? "active" : "")" @onclick='() => _activeTab = "basic"'><i class="bi bi-info-circle"></i> Basic @if (basicHasError && _validationAttempted) { <span class="badge bg-danger rounded-pill">!</span> }</button></li>
                            <li class="nav-item"><button type="button" class="nav-link @(_activeTab == "targets" ? "active" : "")" @onclick='() => _activeTab = "targets"'><i class="bi bi-broadcast"></i> Targets <span class="badge bg-secondary">@(_selectedSnmpIds.Count + _selectedWebhookIds.Count)</span></button></li>
                            <li class="nav-item"><button type="button" class="nav-link @(_activeTab == "templates" ? "active" : "")" @onclick='() => _activeTab = "templates"'><i class="bi bi-file-earmark-code"></i> Templates</button></li>
                            <li class="nav-item"><button type="button" class="nav-link @(_activeTab == "advanced" ? "active" : "")" @onclick='() => _activeTab = "advanced"'><i class="bi bi-sliders"></i> Advanced</button></li>
                        </ul>

                        @if (_activeTab == "basic")
                        {
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                @* K8: autofocus first input. *@
                                <InputText class="form-control" @bind-Value="_form.Name" autofocus />
                                <ValidationMessage For="@(() => _form.Name)" class="text-danger small" />
                            </div>
                            <div class="row mb-3">
                                <div class="col">
                                    <label class="form-label">Mailbox</label>
                                    <InputSelect class="form-select" @bind-Value="_form.MailboxId">
                                        <option value="0">-- Select --</option>
                                        @if (_mailboxes != null)
                                        {
                                            @foreach (var mb in _mailboxes)
                                            {
                                                <option value="@mb.Id">@mb.Name</option>
                                            }
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _form.MailboxId)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label">Rule</label>
                                    <InputSelect class="form-select" @bind-Value="_form.RuleId">
                                        <option value="0">-- Select --</option>
                                        @if (_rules != null)
                                        {
                                            @foreach (var r in _rules)
                                            {
                                                <option value="@r.Id">@r.Name</option>
                                            }
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _form.RuleId)" class="text-danger small" />
                                </div>
                            </div>
                            <div class="form-check mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                                <label class="form-check-label">Active</label>
                            </div>
                        }
                        else if (_activeTab == "targets")
                        {
                            @* G2: Drag-&-Drop dual-list. Click an item to move it between Available
                               and Assigned. Bound to the same _selectedSnmpIds / _selectedWebhookIds
                               sets the legacy checkbox UI used, so SaveJob keeps working unchanged. *@
                            <div class="mb-4">
                                <label class="form-label fw-bold">SNMP Targets</label>
                                <div class="row g-2">
                                    <div class="col">
                                        <div class="card">
                                            <div class="card-header py-1 small text-muted bg-light">Available</div>
                                            <ul class="list-group list-group-flush" style="max-height:200px;overflow:auto;">
                                                @if (_snmpTargets != null)
                                                {
                                                    @foreach (var t in _snmpTargets.Where(x => x.IsActive && !_selectedSnmpIds.Contains(x.Id)))
                                                    {
                                                        <li class="list-group-item list-group-item-action py-1 small" style="cursor:pointer"
                                                            @onclick="() => ToggleSnmp(t.Id, true)">
                                                            <i class="bi bi-arrow-right-circle text-success"></i> @t.Name
                                                            <span class="text-muted">(@t.Host:@t.Port)</span>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="card border-success">
                                            <div class="card-header py-1 small bg-success bg-opacity-10">Assigned (@_selectedSnmpIds.Count)</div>
                                            <ul class="list-group list-group-flush" style="max-height:200px;overflow:auto;">
                                                @if (_snmpTargets != null)
                                                {
                                                    @foreach (var t in _snmpTargets.Where(x => _selectedSnmpIds.Contains(x.Id)))
                                                    {
                                                        <li class="list-group-item list-group-item-action py-1 small" style="cursor:pointer"
                                                            @onclick="() => ToggleSnmp(t.Id, false)">
                                                            <i class="bi bi-x-circle text-danger"></i> @t.Name
                                                            <span class="text-muted">(@t.Host:@t.Port)</span>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                                @if (_snmpTargets == null || !_snmpTargets.Any(t => t.IsActive))
                                {
                                    <div class="text-muted small mt-1">No active SNMP targets. <a href="/snmp-targets">Add one</a></div>
                                }
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Webhook Targets</label>
                                <div class="row g-2">
                                    <div class="col">
                                        <div class="card">
                                            <div class="card-header py-1 small text-muted bg-light">Available</div>
                                            <ul class="list-group list-group-flush" style="max-height:200px;overflow:auto;">
                                                @if (_webhookTargets != null)
                                                {
                                                    @foreach (var t in _webhookTargets.Where(x => x.IsActive && !_selectedWebhookIds.Contains(x.Id)))
                                                    {
                                                        <li class="list-group-item list-group-item-action py-1 small" style="cursor:pointer"
                                                            @onclick="() => ToggleWebhook(t.Id, true)">
                                                            <i class="bi bi-arrow-right-circle text-success"></i> @t.Name
                                                            <span class="text-muted">(@t.Url)</span>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="card border-success">
                                            <div class="card-header py-1 small bg-success bg-opacity-10">Assigned (@_selectedWebhookIds.Count)</div>
                                            <ul class="list-group list-group-flush" style="max-height:200px;overflow:auto;">
                                                @if (_webhookTargets != null)
                                                {
                                                    @foreach (var t in _webhookTargets.Where(x => _selectedWebhookIds.Contains(x.Id)))
                                                    {
                                                        <li class="list-group-item list-group-item-action py-1 small" style="cursor:pointer"
                                                            @onclick="() => ToggleWebhook(t.Id, false)">
                                                            <i class="bi bi-x-circle text-danger"></i> @t.Name
                                                            <span class="text-muted">(@t.Url)</span>
                                                        </li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                                @if (_webhookTargets == null || !_webhookTargets.Any(t => t.IsActive))
                                {
                                    <div class="text-muted small mt-1">No active Webhook targets. <a href="/webhook-targets">Add one</a></div>
                                }
                            </div>
                        }
                        else if (_activeTab == "templates")
                        {
                            <div class="mb-3">
                                <label class="form-label">Trap Template</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="_form.TrapTemplate" />
                                <small class="text-muted">Optional. Use placeholders like {Subject}, {From}, {Severity}.</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Webhook Template</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="_form.WebhookTemplate" />
                                <small class="text-muted">Optional JSON template. Default payload is used when empty.</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">OID Mapping (JSON)</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="_form.OidMapping" />
                                <small class="text-muted">Optional custom OID mapping for SNMP varbinds.</small>
                            </div>
                        }
                        else if (_activeTab == "advanced")
                        {
                            <div class="row mb-3">
                                <div class="col">
                                    <label class="form-label">Max Events/Hour</label>
                                    <InputNumber class="form-control" @bind-Value="_form.MaxEventsPerHour" />
                                </div>
                                <div class="col">
                                    <label class="form-label">Max Active Events</label>
                                    <InputNumber class="form-control" @bind-Value="_form.MaxActiveEvents" />
                                </div>
                                <div class="col">
                                    <label class="form-label">Dedup Window (min)</label>
                                    <InputNumber class="form-control" @bind-Value="_form.DedupWindowMinutes" />
                                </div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<Job>? _jobs;
    private IReadOnlyList<Mailbox>? _mailboxes;
    private IReadOnlyList<Rule>? _rules;
    private IReadOnlyList<SnmpTarget>? _snmpTargets;
    private IReadOnlyList<WebhookTarget>? _webhookTargets;
    private bool _showForm;
    private Job? _editing;
    private JobForm _form = new();
    private string? _error;
    private string? _success;
    private string? _dryRunResult;
    private HashSet<int> _selectedSnmpIds = new();
    private HashSet<int> _selectedWebhookIds = new();
    private bool _loading = true;
    private bool _busy;
    private string _searchTerm = string.Empty;
    private string _activeTab = "basic";
    private bool _validationAttempted;

    /// <summary>
    /// N5: when validation fails on submit, jump back to the Basic tab so the
    /// user immediately sees which required fields are highlighted, and flip
    /// _validationAttempted so the tab error badges become visible.
    /// </summary>
    private void OnInvalidSubmit()
    {
        _validationAttempted = true;
        if (string.IsNullOrWhiteSpace(_form.Name) || _form.MailboxId <= 0 || _form.RuleId <= 0)
            _activeTab = "basic";
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _jobs = await JobService.GetAllAsync();
            _mailboxes = await MailboxService.GetAllAsync();
            _rules = await RuleService.GetAllAsync();
            _snmpTargets = await SnmpTargetService.GetAllAsync();
            _webhookTargets = await WebhookTargetService.GetAllAsync();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private void ShowAddForm()
    {
        _editing = null;
        _form = new JobForm { MaxEventsPerHour = 50, MaxActiveEvents = 200, DedupWindowMinutes = 30, IsActive = true };
        _selectedSnmpIds = new();
        _selectedWebhookIds = new();
        _activeTab = "basic";
        _validationAttempted = false;
        _dryRunResult = null; // N11: clear stale dry-run output from a previous job
        _showForm = true;
    }

    private void ShowEditForm(Job j)
    {
        _editing = j;
        _form = new JobForm
        {
            Name = j.Name, MailboxId = j.MailboxId, RuleId = j.RuleId,
            TrapTemplate = j.TrapTemplate, WebhookTemplate = j.WebhookTemplate, OidMapping = j.OidMapping,
            MaxEventsPerHour = j.MaxEventsPerHour, MaxActiveEvents = j.MaxActiveEvents,
            DedupWindowMinutes = j.DedupWindowMinutes, IsActive = j.IsActive
        };
        _selectedSnmpIds = new HashSet<int>(j.JobSnmpTargets.Select(jst => jst.SnmpTargetId));
        _selectedWebhookIds = new HashSet<int>(j.JobWebhookTargets.Select(jwt => jwt.WebhookTargetId));
        _activeTab = "basic";
        _validationAttempted = false;
        _dryRunResult = null; // N11: clear stale dry-run output from a previous job
        _showForm = true;
    }

    private void CloseForm()
    {
        // H9: reset form state on close so the next open starts clean.
        _showForm = false;
        _editing = null;
        _form = new JobForm();
        _activeTab = "basic";
        _validationAttempted = false;
        _dryRunResult = null;
        _selectedSnmpIds = new();
        _selectedWebhookIds = new();
    }

    private void ToggleSnmp(int id, bool isChecked)
    {
        if (isChecked) _selectedSnmpIds.Add(id);
        else _selectedSnmpIds.Remove(id);
    }

    private void ToggleWebhook(int id, bool isChecked)
    {
        if (isChecked) _selectedWebhookIds.Add(id);
        else _selectedWebhookIds.Remove(id);
    }

    private async Task SaveJob()
    {
        if (_busy) return;
        // P2: Set _busy BEFORE the no-targets confirmation dialog. Previously the
        // flag was only flipped after the confirm returned, which left a window
        // where a fast double-click on Save would race past the `if (_busy) return;`
        // guard at the top and produce two parallel SaveJob calls. The button is
        // also disabled="@_busy" (L2) but only re-renders after this method has
        // already been entered, so the in-method guard is the real defence.
        _busy = true;
        try
        {
            // M1: Warn the user when a job is saved without any notification target assigned.
            // The job is still allowed (e.g. for "logging only" use cases) but the user must
            // confirm that they intentionally created a no-op job.
            if (_selectedSnmpIds.Count == 0 && _selectedWebhookIds.Count == 0)
            {
                var ok = await Confirm.AskAsync(
                    "This job has NO notification targets assigned. Events will be created in the database " +
                    "but no SNMP traps or webhook calls will be sent. Save anyway?");
                if (!ok)
                {
                    _busy = false;
                    return;
                }
            }

            if (_editing != null)
            {
                _editing.Name = _form.Name; _editing.MailboxId = _form.MailboxId; _editing.RuleId = _form.RuleId;
                _editing.TrapTemplate = _form.TrapTemplate;
                _editing.WebhookTemplate = _form.WebhookTemplate; _editing.OidMapping = _form.OidMapping;
                _editing.MaxEventsPerHour = _form.MaxEventsPerHour; _editing.MaxActiveEvents = _form.MaxActiveEvents;
                _editing.DedupWindowMinutes = _form.DedupWindowMinutes; _editing.IsActive = _form.IsActive;
                await JobService.UpdateAsync(_editing);
                await JobService.UpdateTargetAssignmentsAsync(_editing.Id, _selectedSnmpIds, _selectedWebhookIds);
                _success = "Job updated.";
            }
            else
            {
                var job = new Job
                {
                    Name = _form.Name, MailboxId = _form.MailboxId, RuleId = _form.RuleId,
                    TrapTemplate = _form.TrapTemplate,
                    WebhookTemplate = _form.WebhookTemplate, OidMapping = _form.OidMapping,
                    MaxEventsPerHour = _form.MaxEventsPerHour, MaxActiveEvents = _form.MaxActiveEvents,
                    DedupWindowMinutes = _form.DedupWindowMinutes, IsActive = _form.IsActive
                };
                var created = await JobService.CreateAsync(job);
                await JobService.UpdateTargetAssignmentsAsync(created.Id, _selectedSnmpIds, _selectedWebhookIds);
                _success = "Job created.";
            }
            CloseForm();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "saving the job"); }
        finally { _busy = false; }
    }

    private async Task DryRun(int id)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            _dryRunResult = await JobService.DryRunAsync(id);
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "running the dry-run"); }
        finally { _busy = false; }
    }

    private async Task Delete(int id)
    {
        // Q1: set _busy BEFORE the confirm dialog so a fast double-click on
        // Delete cannot produce two parallel DeleteAsync calls. The previous
        // ordering left a window between the confirm and the assignment in
        // which the in-method guard was useless. The finally always resets
        // the flag, including on the cancel-return path.
        if (_busy) return;
        _busy = true;
        try
        {
            var job = _jobs?.FirstOrDefault(j => j.Id == id);
            var name = job?.Name ?? $"#{id}";
            if (!await Confirm.AskAsync($"Delete job '{name}'? This cannot be undone."))
                return;
            await JobService.DeleteAsync(id);
            _success = "Job deleted.";
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "deleting the item"); }
        finally { _busy = false; }
    }

    private class JobForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [Range(1, int.MaxValue, ErrorMessage = "Please select a mailbox.")]
        public int MailboxId { get; set; }

        [Range(1, int.MaxValue, ErrorMessage = "Please select a rule.")]
        public int RuleId { get; set; }

        public string? TrapTemplate { get; set; }
        public string? WebhookTemplate { get; set; }
        public string? OidMapping { get; set; }

        [Range(1, 10000, ErrorMessage = "Max events per hour must be between 1 and 10,000.")]
        public int MaxEventsPerHour { get; set; } = 50;

        [Range(1, 100000, ErrorMessage = "Max active events must be between 1 and 100,000.")]
        public int MaxActiveEvents { get; set; } = 200;

        [Range(0, 1440, ErrorMessage = "Dedup window must be between 0 and 1440 minutes.")]
        public int DedupWindowMinutes { get; set; } = 30;

        public bool IsActive { get; set; } = true;
    }
}
