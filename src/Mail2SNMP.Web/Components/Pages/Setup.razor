@page "/setup"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Mail2SNMP.Models.Entities
@inject UserManager<AppUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Initial Setup - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow" style="max-width: 500px; width: 100%;">
        <div class="card-body p-4">
            <h3 class="text-center mb-2 fw-bold">Mail2SNMP</h3>
            <p class="text-center text-muted mb-4">Initial Setup - Create Admin Account</p>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            @if (_setupComplete)
            {
                <div class="alert alert-success">
                    Admin account created successfully. You can now <a href="/login">sign in</a>.
                </div>
            }
            else if (_alreadySetup)
            {
                <div class="alert alert-info">
                    Setup has already been completed. <a href="/login">Sign in</a> with your admin account.
                </div>
            }
            else
            {
                <EditForm Model="_form" OnValidSubmit="HandleSetup" FormName="setup">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="_form.Email" />
                        <ValidationMessage For="@(() => _form.Email)" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Display Name</label>
                        <InputText class="form-control" @bind-Value="_form.DisplayName" />
                        <ValidationMessage For="@(() => _form.DisplayName)" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        @* T11: cap password input at 256 characters to prevent UI lag from
                           pasting very large strings (live strength indicator runs on every keystroke). *@
                        <InputText type="password" class="form-control" maxlength="256"
                                   @bind-Value="_form.Password" @bind-Value:event="oninput" />
                        <ValidationMessage For="@(() => _form.Password)" class="text-danger small" />
                        @* I11: visible hint so users pasting a >256-char password are not confused
                           by the silent truncation enforced by maxlength. *@
                        <small class="text-muted">Maximum length is 256 characters.</small>
                        @* L3: live password strength indicator *@
                        @{
                            var hasMinLen = _form.Password.Length >= 12;
                            var hasUpper = _form.Password.Any(char.IsUpper);
                            var hasLower = _form.Password.Any(char.IsLower);
                            var hasDigit = _form.Password.Any(char.IsDigit);
                            var hasSpecial = _form.Password.Any(c => !char.IsLetterOrDigit(c));
                            var score = (hasMinLen ? 1 : 0) + (hasUpper ? 1 : 0) + (hasLower ? 1 : 0) + (hasDigit ? 1 : 0) + (hasSpecial ? 1 : 0);
                            var strengthClass = score switch { 0 or 1 => "bg-danger", 2 or 3 => "bg-warning", 4 => "bg-info", _ => "bg-success" };
                            var strengthLabel = score switch { 0 => "Empty", 1 or 2 => "Weak", 3 => "Fair", 4 => "Good", _ => "Strong" };
                        }
                        <div class="progress mt-2" style="height: 6px;">
                            <div class="progress-bar @strengthClass" role="progressbar" style="width: @(score * 20)%;"></div>
                        </div>
                        <small class="text-muted d-block mt-1">Strength: <strong>@strengthLabel</strong></small>
                        <ul class="list-unstyled small mt-1 mb-0">
                            <li class="@(hasMinLen ? "text-success" : "text-muted")"><i class="bi @(hasMinLen ? "bi-check-circle-fill" : "bi-circle")"></i> At least 12 characters</li>
                            <li class="@(hasUpper ? "text-success" : "text-muted")"><i class="bi @(hasUpper ? "bi-check-circle-fill" : "bi-circle")"></i> Uppercase letter</li>
                            <li class="@(hasLower ? "text-success" : "text-muted")"><i class="bi @(hasLower ? "bi-check-circle-fill" : "bi-circle")"></i> Lowercase letter</li>
                            <li class="@(hasDigit ? "text-success" : "text-muted")"><i class="bi @(hasDigit ? "bi-check-circle-fill" : "bi-circle")"></i> Digit</li>
                            <li class="@(hasSpecial ? "text-success" : "text-muted")"><i class="bi @(hasSpecial ? "bi-check-circle-fill" : "bi-circle")"></i> Special character</li>
                        </ul>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <InputText type="password" class="form-control" @bind-Value="_form.ConfirmPassword" @bind-Value:event="oninput" />
                        @if (!string.IsNullOrEmpty(_form.ConfirmPassword) && _form.Password != _form.ConfirmPassword)
                        {
                            <small class="text-danger d-block mt-1"><i class="bi bi-x-circle"></i> Passwords do not match</small>
                        }
                        else if (!string.IsNullOrEmpty(_form.ConfirmPassword))
                        {
                            <small class="text-success d-block mt-1"><i class="bi bi-check-circle"></i> Passwords match</small>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary w-100" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span>Create Admin Account</span>
                        }
                    </button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    private SetupForm _form = new();
    private string? _error;
    private bool _setupComplete;
    private bool _alreadySetup;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        var adminUsers = await UserManager.GetUsersInRoleAsync("Admin");
        if (adminUsers.Count > 0)
            _alreadySetup = true;
    }

    private async Task HandleSetup()
    {
        _error = null;
        _submitting = true;

        try
        {
            // Double-check no admin exists (race condition guard)
            var existingAdmins = await UserManager.GetUsersInRoleAsync("Admin");
            if (existingAdmins.Count > 0)
            {
                _alreadySetup = true;
                return;
            }

            if (_form.Password != _form.ConfirmPassword)
            {
                _error = "Passwords do not match.";
                return;
            }

            var user = new AppUser
            {
                UserName = _form.Email,
                Email = _form.Email,
                DisplayName = _form.DisplayName,
                EmailConfirmed = true
            };

            var result = await UserManager.CreateAsync(user, _form.Password);
            if (!result.Succeeded)
            {
                _error = string.Join(" ", result.Errors.Select(e => e.Description));
                return;
            }

            await UserManager.AddToRoleAsync(user, "Admin");

            // N7: post-create race-condition guard. Two concurrent /setup requests
            // can both pass the initial admin check. After successfully creating
            // and assigning the role, re-query the admin role and verify we are
            // the only one. If another admin sneaked in, roll back our user so
            // exactly one admin remains.
            var allAdmins = await UserManager.GetUsersInRoleAsync("Admin");
            if (allAdmins.Count > 1)
            {
                // T8: the rollback delete itself can theoretically fail. If it does,
                // surface a clear error so the operator knows there are now two
                // admin users that need to be reconciled manually.
                try
                {
                    var deleteResult = await UserManager.DeleteAsync(user);
                    if (!deleteResult.Succeeded)
                    {
                        _error = "Race condition detected: another admin was created concurrently. " +
                                 "Rollback of this account FAILED — please open the Users page and " +
                                 "delete the duplicate admin manually. Errors: " +
                                 string.Join(" ", deleteResult.Errors.Select(e => e.Description));
                        return;
                    }
                }
                catch (Exception rollbackEx)
                {
                    _error = "Race condition detected: another admin was created concurrently. " +
                             "Rollback of this account FAILED — please open the Users page and " +
                             "delete the duplicate admin manually. Reason: " + rollbackEx.Message;
                    return;
                }
                _alreadySetup = true;
                return;
            }
            _setupComplete = true;
        }
        finally
        {
            _submitting = false;
        }
    }

    private class SetupForm
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string DisplayName { get; set; } = "Administrator";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(12)]
        public string Password { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
