@page "/events"
@rendermode InteractiveServer
@inject IEventService EventService
@inject IJSRuntime JS
@inject IOptions<HelpSettings> Help

<PageTitle>Events - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Events <HelpLink Url="@Help.Value.Events" /></h3>
    <button class="btn btn-outline-success btn-sm" @onclick="ExportCsv" disabled="@(_events == null || _events.Count == 0)">
        <i class="bi bi-download"></i> Export CSV
    </button>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

<div class="mb-3">
    <label class="form-label me-2">Filter by State:</label>
    @* I12: aria-pressed announces the active filter to screen readers; the visual
       primary/outline-primary contrast alone is invisible to assistive tech. *@
    <div class="btn-group" role="group" aria-label="Filter events by state">
        <button class="btn btn-sm @(_stateFilter == null ? "btn-primary" : "btn-outline-primary")"
                aria-pressed="@(_stateFilter == null ? "true" : "false")"
                @onclick="() => FilterByState(null)">All</button>
        @foreach (var state in Enum.GetValues<EventState>())
        {
            <button class="btn btn-sm @(_stateFilter == state ? "btn-primary" : "btn-outline-primary")"
                    aria-pressed="@(_stateFilter == state ? "true" : "false")"
                    @onclick="() => FilterByState(state)">@state</button>
        }
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_events == null || _events.Count == 0)
{
    <div class="alert alert-info">No events found@(_stateFilter.HasValue ? $" with state '{_stateFilter}'." : ".")</div>
}
else
{
    var totalPages = (int)Math.Ceiling(_events.Count / (double)_pageSize);
    var paged = _events.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Job</th>
                <th>State</th>
                <th>Severity</th>
                <th>From</th>
                <th>Subject</th>
                <th>Rule</th>
                <th>Hits</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var evt in paged)
            {
                <tr>
                    <td>@evt.Id</td>
                    <td>@(evt.Job?.Name ?? $"ID:{evt.JobId}")</td>
                    <td><span class="badge bg-@GetStateColor(evt.State)">@evt.State</span></td>
                    <td><span class="badge bg-@GetSeverityColor(evt.Severity)">@evt.Severity</span></td>
                    <td class="small">@evt.MailFrom</td>
                    <td class="small">@evt.Subject</td>
                    <td class="small">@evt.RuleName</td>
                    <td>@evt.HitCount</td>
                    <td class="small">@evt.CreatedUtc.ToString("g")</td>
                    <td>
                        @if (evt.State == EventState.New || evt.State == EventState.Notified)
                        {
                            <button class="btn btn-outline-warning btn-sm me-1" @onclick="() => Acknowledge(evt.Id)" disabled="@_busy"><i class="bi bi-check"></i> Ack</button>
                        }
                        @if (evt.State != EventState.Resolved && evt.State != EventState.Suppressed)
                        {
                            <button class="btn btn-outline-success btn-sm me-1" @onclick="() => Resolve(evt.Id)" disabled="@_busy"><i class="bi bi-check2-all"></i> Resolve</button>
                        }
                        @if (evt.State != EventState.Suppressed)
                        {
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => Suppress(evt.Id)" disabled="@_busy"><i class="bi bi-volume-mute"></i> Suppress</button>
                        }
                        <button class="btn btn-outline-info btn-sm" @onclick="() => Replay(evt.Id)" disabled="@_busy"><i class="bi bi-arrow-clockwise"></i> Replay</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<nav class="d-flex justify-content-between align-items-center" aria-label="Pagination">
    <small class="text-muted">Showing @((_currentPage - 1) * _pageSize + 1)–@Math.Min(_currentPage * _pageSize, _events.Count) of @_events.Count events</small>
    @if (totalPages > 1)
    {
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => _currentPage = Math.Max(1, _currentPage - 1)">Previous</button>
            </li>
            <li class="page-item disabled" aria-current="page"><span class="page-link">Page @_currentPage of @totalPages</span></li>
            <li class="page-item @(_currentPage == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => _currentPage = Math.Min(totalPages, _currentPage + 1)">Next</button>
            </li>
        </ul>
    }
</nav>
}

@code {
    private IReadOnlyList<Event>? _events;
    private EventState? _stateFilter;
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _busy;
    private const int _pageSize = 50;
    private int _currentPage = 1;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _events = await EventService.GetAllAsync(_stateFilter);
            _currentPage = 1;
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private async Task FilterByState(EventState? state)
    {
        _stateFilter = state;
        // J8: Always reset to page 1 when the filter changes — otherwise a user
        // sitting on page 5 of "All" can hit "Acknowledged" and land on an empty
        // page because the smaller filtered set has fewer pages.
        _currentPage = 1;
        await LoadData();
    }

    private async Task Acknowledge(long id)
    {
        if (_busy) return;
        _busy = true;
        try { await EventService.AcknowledgeAsync(id, "web-user"); _success = "Event acknowledged."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "the operation"); }
        finally { _busy = false; }
    }

    private async Task Resolve(long id)
    {
        if (_busy) return;
        _busy = true;
        try { await EventService.ResolveAsync(id, "web-user"); _success = "Event resolved."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "the operation"); }
        finally { _busy = false; }
    }

    private async Task Suppress(long id)
    {
        if (_busy) return;
        _busy = true;
        try { await EventService.SuppressAsync(id); _success = "Event suppressed."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "the operation"); }
        finally { _busy = false; }
    }

    private async Task Replay(long id)
    {
        if (_busy) return;
        _busy = true;
        try { await EventService.ReplayAsync(id); _success = "Event replayed."; await LoadData(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "the operation"); }
        finally { _busy = false; }
    }

    // T15: CSV export of the currently filtered event list. Mirrors the
    // pattern from AuditLog.razor — RFC4180 quoting, downloadText JS interop,
    // friendly error message on failure.
    private async Task ExportCsv()
    {
        if (_events == null || _events.Count == 0) return;
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("CreatedUtc,JobId,RuleName,Severity,State,HitCount,Subject,MailFrom,MessageId");
            foreach (var e in _events)
            {
                sb.Append(e.CreatedUtc.ToString("o")).Append(',')
                  .Append(e.JobId).Append(',')
                  .Append(Csv(e.RuleName)).Append(',')
                  .Append(Csv(e.Severity.ToString())).Append(',')
                  .Append(Csv(e.State.ToString())).Append(',')
                  .Append(e.HitCount).Append(',')
                  .Append(Csv(e.Subject)).Append(',')
                  .Append(Csv(e.MailFrom)).Append(',')
                  .AppendLine(Csv(e.MessageId));
            }
            var filename = $"events-{DateTime.UtcNow:yyyyMMdd-HHmmss}.csv";
            await JS.InvokeVoidAsync("mail2snmp.downloadText", filename, "text/csv;charset=utf-8", sb.ToString());
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "exporting events"); }
    }

    private static string Csv(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.IndexOfAny(new[] { ',', '"', '\r', '\n' }) >= 0)
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        return value;
    }

    private static string GetStateColor(EventState s) => s switch
    {
        EventState.New => "primary",
        EventState.Notified => "info",
        EventState.Acknowledged => "warning",
        EventState.Resolved => "success",
        EventState.Suppressed => "secondary",
        EventState.Expired => "dark",
        _ => "secondary"
    };

    private static string GetSeverityColor(Severity s) => s switch
    {
        Severity.Critical => "danger",
        Severity.Error => "danger",
        Severity.Warning => "warning",
        _ => "info"
    };
}
