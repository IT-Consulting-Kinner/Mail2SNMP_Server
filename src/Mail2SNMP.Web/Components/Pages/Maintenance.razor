@page "/maintenance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Operator")]
@rendermode InteractiveServer
@inject IMaintenanceWindowService MaintenanceService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Maintenance Windows - Mail2SNMP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Maintenance Windows</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm"><i class="bi bi-plus-circle"></i> Add Window</button>
</div>

<AutoDismissAlert Type="danger"  @bind-Message="_error" />
<AutoDismissAlert Type="success" @bind-Message="_success" AutoDismissSeconds="5" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"><span class="visually-hidden">Loading...</span></div></div>
}
else
{
<div class="row g-3">
    @if (_windows != null)
    {
        @foreach (var w in _windows.OrderBy(x => x.StartUtc))
        {
            var isActive = w.IsActive && w.StartUtc <= DateTime.UtcNow && w.EndUtc >= DateTime.UtcNow;
            var isPast = w.EndUtc < DateTime.UtcNow;
            var isFuture = w.StartUtc > DateTime.UtcNow;

            <div class="col-md-6 col-lg-4">
                @* L1: Use plain Bootstrap 5.1 utility classes — the project ships
                   bootstrap.min.css v5.1.0 which does NOT include the *-subtle /
                   *-emphasis utilities that K7 attempted to use (introduced in
                   5.2). Without the fallback those classes silently no-op'd and
                   the card headers lost their background entirely. The contrast
                   of bg-warning (#ffc107) against text-dark (#212529) is ~11:1,
                   well above WCAG AA for large text in either light or dark mode. *@
                <div class="card @(isActive ? "border-warning" : isPast ? "border-secondary" : "border-primary")">
                    <div class="card-header d-flex justify-content-between align-items-center @(isActive ? "bg-warning text-dark" : isPast ? "bg-secondary text-white" : "bg-primary text-white")">
                        <strong>@w.Name</strong>
                        @if (isActive)
                        {
                            <span class="badge bg-dark">ACTIVE</span>
                        }
                        else if (isPast)
                        {
                            @* J9: bg-secondary auto-adapts to dark mode via Bootstrap 5.3 CSS vars,
                               unlike bg-light text-dark which produced poor contrast in dark theme. *@
                            <span class="badge bg-secondary">Past</span>
                        }
                        else if (isFuture)
                        {
                            <span class="badge bg-info text-dark">Scheduled</span>
                        }
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>Start:</strong> @w.StartUtc.ToLocalTime().ToString("g") <small class="text-muted">(local)</small></p>
                        <p class="mb-1"><strong>End:</strong> @w.EndUtc.ToLocalTime().ToString("g") <small class="text-muted">(local)</small></p>
                        <p class="mb-1"><strong>Scope:</strong> @w.Scope</p>
                        @if (!string.IsNullOrEmpty(w.RecurringCron))
                        {
                            <p class="mb-1"><strong>Cron:</strong> <code>@w.RecurringCron</code></p>
                        }
                        <p class="mb-1 text-muted small">Created by @w.CreatedBy on @w.CreatedUtc.ToString("g")</p>
                    </div>
                    <div class="card-footer text-end">
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(w.Id)" disabled="@_busy"><i class="bi bi-trash"></i> Delete</button>
                    </div>
                </div>
            </div>
        }

        @if (_windows.Count == 0)
        {
            <div class="col-12"><div class="alert alert-info">No maintenance windows configured. Click <strong>Add Window</strong> to schedule one.</div></div>
        }
    }
</div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Maintenance Window</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                            <ValidationMessage For="@(() => _form.Name)" class="text-danger small" />
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label">Start (local time)</label>
                                <InputDate class="form-control" Type="InputDateType.DateTimeLocal" @bind-Value="_form.StartLocal" />
                                <small class="form-text text-muted">Stored as @_form.StartLocal.ToUniversalTime().ToString("yyyy-MM-dd HH:mm") UTC</small>
                            </div>
                            <div class="col">
                                <label class="form-label">End (local time)</label>
                                <InputDate class="form-control" Type="InputDateType.DateTimeLocal" @bind-Value="_form.EndLocal" />
                                <small class="form-text text-muted">Stored as @_form.EndLocal.ToUniversalTime().ToString("yyyy-MM-dd HH:mm") UTC</small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Scope</label>
                            <InputText class="form-control" @bind-Value="_form.Scope" />
                            <small class="text-muted">Use "All" for global or specify job/mailbox IDs</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Recurring Cron (optional)</label>
                            <InputText class="form-control" @bind-Value="_form.RecurringCron" placeholder="e.g. 0 8 * * 1-5" />
                            <small class="text-muted">
                                H6: 5-field cron, evaluated in <strong>UTC</strong>.
                                Format: <code>minute hour day-of-month month day-of-week</code>.
                                Examples: <code>0 8 * * *</code> = 08:00 UTC daily; <code>0 8 * * 1-5</code> = 08:00 UTC weekdays.
                                The window's <em>duration</em> is taken from Start/End above and re-applied at every cron occurrence.
                            </small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_busy">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<MaintenanceWindow>? _windows;
    private bool _showForm;
    private MaintenanceForm _form = new();
    private string? _error;
    private string? _success;
    private string _currentUserName = "system";
    private bool _loading = true;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _currentUserName = authState.User.Identity?.Name ?? "system";
        }
        catch { /* fallback to "system" */ }
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try { _windows = await MaintenanceService.GetAllAsync(); }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "loading data"); }
        finally { _loading = false; }
    }

    private void ShowAddForm()
    {
        _form = new MaintenanceForm
        {
            StartLocal = DateTime.Now,
            EndLocal = DateTime.Now.AddHours(2),
            Scope = "All"
        };
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task Save()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            // M9: Convert local-time form input to UTC for storage so the
            // backend logic always compares in a single zone.
            var window = new MaintenanceWindow
            {
                Name = _form.Name,
                StartUtc = _form.StartLocal.ToUniversalTime(),
                EndUtc = _form.EndLocal.ToUniversalTime(),
                Scope = _form.Scope,
                RecurringCron = _form.RecurringCron,
                CreatedBy = _currentUserName
            };
            await MaintenanceService.CreateAsync(window);
            _success = "Maintenance window created.";
            CloseForm();
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "saving the item"); }
        finally { _busy = false; }
    }

    private async Task Delete(int id)
    {
        // Q1: see Jobs.Delete — _busy must be set BEFORE the confirm dialog.
        if (_busy) return;
        _busy = true;
        try
        {
            var w = _windows?.FirstOrDefault(x => x.Id == id);
            var name = w?.Name ?? $"#{id}";
            if (!await JS.TryConfirmAsync($"Delete maintenance window '{name}'? This cannot be undone."))
                return;
            await MaintenanceService.DeleteAsync(id);
            _success = "Window deleted.";
            await LoadData();
        }
        catch (Exception ex) { _error = ErrorMessageFormatter.ToFriendly(ex, "deleting the item"); }
        finally { _busy = false; }
    }

    private class MaintenanceForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        // M9: Inputs are bound to local-time fields and converted to UTC on save.
        [Required(ErrorMessage = "Start time is required.")]
        public DateTime StartLocal { get; set; }

        [Required(ErrorMessage = "End time is required.")]
        public DateTime EndLocal { get; set; }

        [Required(ErrorMessage = "Scope is required.")]
        public string Scope { get; set; } = "All";

        public string? RecurringCron { get; set; }
    }
}
